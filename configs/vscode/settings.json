{
    // Disabling Telemetry:
    "telemetry.feedback.enabled": false,
    "telemetry.telemetryLevel": "off",
    "python.analysis.enablePerfTelemetry": false,
    "telemetry.editStats.details.enabled": false,
    "telemetry.editStats.showDecorations": false,
    "telemetry.editStats.enabled": false,
    "editor.experimental.treeSitterTelemetry": false,
    "python.analysis.reportExtraTelemetry": false,
    "python.analysis.enableSnippetExtraTelemetry": false,
    "telemetry.editStats.showStatusBar": false,
    "gitlens.telemetry.enabled": false,
    "rest-client.enableTelemetry": false,
    "code-runner.enableAppInsights": false,
    // Editor:
    "vim.handleKeys": {
        "<C-c>": false,
        "<C-p>": false,
        "<C-d>": false,
        "<C-s>": false,
        "<C-z>": false,
        "<C-b>": false,
        "<C-k>": false,
        "<C-t>": false,
        "<C-f>": false,
        "<C-a>": false
    },
    "editor.formatOnSave": true,
    "editor.mouseWheelZoom": true,
    "editor.lineNumbers": "relative",
    "editor.minimap.enabled": false,
    "editor.smoothScrolling": true,
    "editor.aiStats.enabled": false,
    // font:
    "editor.fontFamily": "JetBrains Mono",
    "editor.fontSize": 14,
    "terminal.integrated.fontSize": 14,
    "notebook.output.fontSize": 12,
    "chat.editor.fontSize": 12,
    "debug.console.fontSize": 12,
    "editor.fontLigatures": true,
    "terminal.integrated.fontLigatures.enabled": true,
    "terminal.integrated.hideOnStartup": "always",
    "terminal.integrated.allowMnemonics": true,
    "terminal.integrated.detectLocale": "on",
    // git:
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    // window:
    "window.menuBarVisibility": "compact",
    "window.closeWhenEmpty": true,
    "window.confirmBeforeClose": "never",
    "window.autoDetectColorScheme": false,
    "window.commandCenter": false,
    "zenMode.showTabs": "none",
    "zenMode.centerLayout": true,
    // debug:
    "debug.confirmOnExit": "never",
    "debug.console.closeOnEnd": true,
    "debug.showVariableTypes": false,
    // container:
    "containers.containerClient": "com.microsoft.visualstudio.containers.podman",
    "containers.orchestratorClient": "com.microsoft.visualstudio.orchestrators.podmancompose",
    // workbench:
    "workbench.layoutControl.enabled": false,
    "workbench.statusBar.visible": false,
    "workbench.sideBar.location": "right",
    "workbench.settings.editor": "json",
    "workbench.startupEditor": "none",
    "workbench.colorTheme": "Experimental Dark",
    "explorer.confirmDelete": false,
    // language specific settings:
    "C_Cpp.intelliSenseEngine": "disabled", // conflict with clangd
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
        "editor.formatOnPaste": true,
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[javascript]": {
        "editor.maxTokenizationLineLength": 2500,
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "cmake.showNotAllDocumentsSavedQuestion": false,
    "extensions.autoUpdate": false,
    "roo-cline.debug": false,
    "roo-cline.allowedCommands": [
        "git log",
        "git diff",
        "git show",
        "htmlq",
        "head",
        "content",
        "./bin/content",
        "bin/zarebin",
        "bin/url",
        "bin/content --no-curl",
        "bin/url get",
        "bin/url list"
    ],
    "roo-cline.deniedCommands": []
}