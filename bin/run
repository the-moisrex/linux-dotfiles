#!/bin/bash

RED="\033[0;31m"
GRAY="\033[0;37m"
GREEN="\033[0;32m"
YELLOW="\033[0;33m"
NC="\033[0m" # No Color

curdir=$(realpath "$(dirname "$0")")

# Force compilers and build systems to output color
export CLICOLOR_FORCE=1
export FORCE_COLOR=1
export GCC_COLORS="error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01"
export CMAKE_COLOR_DIAGNOSTICS=ON
export NINJA_STATUS=$'\033[32m[%f/%t] \033[0m'



if git rev-parse --show-toplevel >/dev/null 2>&1; then
    GIT_ROOT="$(git rev-parse --show-toplevel)"
else
    gitroot=".git";
    until [ "$(realpath "$gitroot" 2>/dev/null)" = "/.git" ] || \
          [ "$(realpath "$gitroot" 2>/dev/null)" = "/" ] || \
          [ -d "$gitroot" ]; do
      gitroot="../${gitroot}";
    done;
    GIT_ROOT="$(basename "$gitroot/..")"
fi

proj_dir="$GIT_ROOT";
should_clean=true;
build_dir="";
is_interactive=true;
is_oneline=false;
notify_id=10889

# find the project directories
function calculate_build_dir {
    if [ ! -z "$build_dir" ]; then
      return
    fi
    if [ -f "$proj_dir/CMakeLists.txt" ]; then
        build_dir=$(find "$proj_dir" -maxdepth 2 -type f \( -name build.ninja -o -name CMakeCache.txt \) | xargs -l dirname | sort -u | xargs -l basename);
    else
        build_dir=$(find "$proj_dir" -maxdepth 2 -type f \( -name build.ninja -o -name CMakeCache.txt -o -name Makefile \) | xargs -l dirname | sort -u | xargs -l basename);
    fi
    if $is_interactive; then
        if [ "$(echo -e "$build_dir" | wc -l)" != "1" ]; then
            if ! command -v dialog >/dev/null; then
                echo "Install the 'dialog' command.";
                exit 1;
            fi
            build_options=()
            readarray -t build_options <<< "$build_dir";
            echo "${build_options[@]}"
            build_dir=$(dialog --stdout --erase-on-exit --no-cancel --no-items --ok-label "Run" --trim --scrollbar --menu "Select the build directory:" 20 50 ${#build_options[@]} "${build_options[@]}")
        fi
    else
        # select the first choice in non-interactive modes
        build_dir=$(echo -e "$build_dir" | head -n 1)
    fi
    build_dir=$(realpath "$proj_dir/$build_dir")
}


function print_cmake_targets {
    # current_version=$(cmake --version | grep "cmake version" | cut -d" " -f3)
    # version="3.27"
    # if [[ $(echo -e "$version\n$current_version" | sort --version-sort -r | head -n1) == "$current_version" ]]; then
    #     # newer versions of cmake
    #     cmake --build "$build_dir" --target help | cut -d" " -f2 | tail -n +2
    # else
        # older versions of cmake
        # you can also use "ninja -t targets"
        # cmake --build "$build_dir" --target help | awk 'BEGIN{ FS=":" } !/: phony|\/|CMAKE_SYMLINK_LIBRARY|\.json|^clean|\[|build.ninja|^help/ { print $1 }'
        cmake --build "$build_dir" --target help | awk 'BEGIN{ FS=":" } !/\/|CMAKE_SYMLINK_LIBRARY|\.json|^clean|\[|build.ninja|^help|^install|^rebuild_cache|^edit_cache|^list_install_components|^codegen|^The following are/ { gsub("... ", "", $1); print $1 }'
    # fi
}

function print_ninja_targets {
    if [ -f "$build_dir/build.ninja" ]; then
      awk '/^build [A-Z\-a-z0-9]*:/{ gsub(":", "", $2); print $2 }' "$build_dir/build.ninja"
    fi
}

function print_makefile_targets {
    if [ -f "$build_dir/Makefile" ]; then
      awk '/^[a-z\-A-Z0-9]+\s*:/{ gsub(":", "", $1); print $1 }' "$build_dir/Makefile"
    fi
}

function filter_targets {
    sort -u | grep -vE "^(install|clean|help|all|depend|preinstall|codegen|list_install_components|)$" | grep -vE "\s"
}

function print_targets {
  is_interactive=false;
  calculate_build_dir;
  {
    ninja_res=$(print_ninja_targets)
    makefile_res=$(print_makefile_targets)
    if [ -z "$ninja_res" ] && [ -z "$makefile_res" ]; then
      # don't run cmake unless ninja and makefile come up empty (because cmake is slow)
      print_cmake_targets;
    else
      echo "$ninja_res";
      echo "$makefile_res";
    fi
  } | filter_targets;
}

function run {
  scan_build="";
  debug_cmd=""
  if [ "$1" == "analyze" ]; then
      scan_build="scan-build"
      shift;
  elif [ "$1" == "lldb" ]; then
      debug_cmd="lldb";
      shift;
  elif [ "$1" == "gdb" ]; then
      debug_cmd="gdb";
      shift;
  fi

  calculate_build_dir

  execfile="$*";
  orig_execfile="$execfile"

  if [ -d "$GIT_ROOT" ] && [ -d "$proj_dir" ] && [ -d "$build_dir" ]; then
    if [ -f "$build_dir/CMakeCache.txt" ]; then
      build_cmd="cmake --build '$build_dir' --target $execfile";
    elif [ -f "$build_dir/build.ninja" ]; then
      build_cmd="ninja -C '$build_dir' -v $execfile";
    elif [ -f "Makefile" ]; then
      build_cmd="make -C '$build_dir' $execfile";
    else
      echo -e "${RED}Wrong build directory: '${build_dir}'${NC}";
      return;
    fi;

    if $is_oneline; then
        if eval "$scan_build $build_cmd" &>/dev/null; then
            if [ -f "$build_dir/$execfile" ]; then
                execfile="$build_dir/$execfile";
            else
                execfile="$(find "$build_dir" -type f -executable -name "$execfile" -print -quit)";
            fi
            
            if [ -f "$execfile" ]; then
                if eval "$scan_build $debug_cmd $execfile" &>/dev/null; then
                    echo -e "${GREEN}[SUCCESS] Build & Run Passed:${NC} $orig_execfile"
                    exit 0
                else
                    echo -e "${YELLOW}[FAILED RUN] Build Succeeded, Run Failed:${NC} $orig_execfile"
                    exit 1
                fi
            else
                # Sometimes a target doesn't produce an executable (e.g. object file)
                echo -e "${GREEN}[SUCCESS] Build Passed (No Executable Found):${NC} $orig_execfile"
                exit 0
            fi
        else
            echo -e "${RED}[FAILED BUILD] Compilation Failed:${NC} $orig_execfile"
            exit 1
        fi
        return
    fi

    if $should_clean; then
        clear;
    fi
    echo -e "${GRAY}Project root:${NC}    $proj_dir"
    echo -e "${GRAY}Build Directory:${NC} $build_dir"
    echo -e "${GRAY}Build command:${NC}   $scan_build $build_cmd"
    echo -e "${GRAY}Exec command:${NC}    $scan_build $debug_cmd $execfile"
    #if eval "stdbuf -i0 -o0 -e0 $scan_build $build_cmd"; then
    if script -q -e -c "stdbuf -i0 -o0 -e0 $scan_build $build_cmd" /dev/null; then
      [ ! $is_interactive ] && timeout 1s notify-send --replace-id ${notify_id} -t 800 -i utilities-terminal -a "Compiler" "$execfile Compiled Seccessfully.";
      if [ -f "$build_dir/$execfile" ]; then
        execfile="$build_dir/$execfile";
      else
        execfile="$(find "$build_dir" -type f -executable -name "$execfile" -print -quit)";
      fi
      echo
      echo "----------------------------------------------------------------"
      echo -e "${GRAY}Exec command:${NC}    $scan_build $debug_cmd $execfile"
      echo
      if [ -f "$execfile" ] && eval "$scan_build $debug_cmd $execfile"; then
        [ ! $is_interactive ] && timeout 1s notify-send --replace-id ${notify_id} -t 1000 -i utilities-terminal -a "Compiler" "$execfile Passed";
        exit 0
      else
        [ ! $is_interactive ] && timeout 1s notify-send --replace-id ${notify_id} -t 1000 -i utilities-terminal -a "Compiler" "$execfile Failed";
        exit 1
      fi;
    else
      [ ! $is_interactive ] && timeout 1s notify-send --replace-id ${notify_id} -t 800 -i utilities-terminal -a "Compiler" "$execfile Compilation Failed.";
      exit 1
    fi;
  else
    echo -e "${RED}Project Root not found.${NC}"
  fi;
}


function keep-running {
  build_dir=$(find "$proj_dir" -maxdepth 2 -type f -name build.ninja | xargs -l dirname | sort -u | head -n 1 | xargs -l basename);
  if [ -f "$build_dir/build.ninja" ]; then
    # check build.ninja for the main C++ file so we can find the dependencies of it
    cpp_file=$(awk "/build .*\.o:.*_${1}_/{ print \$4 }" "$build_dir/build.ninja")
    if [ -f "$cpp_file" ]; then
      "$curdir/clang.deps" "$cpp_file" | entr -crs "$0 --build-dir '${build_dir}' $@";
      return
    fi
  fi
  is_interactive=false
  build_dir=""
  calculate_build_dir
  git -C "$proj_dir" ls-files -cm | entr -rcs "$0 --build-dir '${build_dir}' $@";
}

function build-step {
  target="$1"
  build_cmd="$2"
  RED="\033[0;31m"
  GRAY="\033[0;37m"
  GREEN="\033[0;32m"
  NC="\033[0m" # No Color
  # cmd="stdbuf -i0 -o0 -e0 $build_cmd &>/dev/null && echo -e \"${GREEN} - [SUCCESS]   $target ${NC}\" || echo -e \"${RED} - [FAILED]    $target ${NC} \t\t $build_cmd\""
  # echo -e "${GRAY} - [COMPILING] $target${NC}: $build_cmd"
  if eval "stdbuf -i0 -o0 -e0  $build_cmd" &>/dev/null; then
    echo -e "${GREEN} - [$?][SUCCESS]   $target ${NC}";
  else
    echo -e "${RED} - [$?][FAILED]    $target ${NC} \t\t $build_cmd";
  fi
}

function build-report {
  if [ -z "$*" ]; then
    echo "Targets are empty, specify some;"
    echo " Usage Example:"
    echo "     # test all the targets:"
    echo "   $ run targets | grep test- | xargs run report"
    exit 1
  fi


  calculate_build_dir

  if [ -d "$GIT_ROOT" ] && [ -d "$proj_dir" ] && [ -d "$build_dir" ]; then
    if $should_clean; then
        clear;
    fi
    echo -e "${GRAY}Project root:${NC}    $proj_dir"
    echo -e "${GRAY}Build Directory:${NC} $build_dir"
    
    all_cmds=""
    for target in "$@"; do
      if [ -f "$build_dir/CMakeCache.txt" ]; then
        build_cmd="cmake --build '$build_dir' --target $target";
      elif [ -f "$build_dir/build.ninja" ]; then
        build_cmd="ninja -C '$build_dir' -v $target";
      elif [ -f "Makefile" ]; then
        build_cmd="make -C '$build_dir' $target";
      else
        echo -e "${RED}Wrong build directory: '${build_dir}'${NC}";
        return;
      fi;
      if command -v parallel &>/dev/null; then
        all_cmds="${all_cmds}\n build-step '$target' \"$build_cmd\""
        # all_cmds="${all_cmds}\n$cmd"
      else
        build-step "$target" "$build_cmd";
      fi
    done
    export -f build-step # exposing to 'parallel'
    if command -v parallel &>/dev/null; then
      echo -ne "$all_cmds" | parallel -j+0
    fi
  else
    echo -e "${RED}Project Root not found.${NC}"
  fi;
}


exec_name=$(realpath "$0");
function print_help {
    echo "$exec_name help"
    echo "           [target]                        # the target to compile/run"
    echo "           keep [target]                   # keep running the target"
    echo "           analyze/scan-build [target]     # "
    echo "           lldb/gdb [target]               # run lldb/gdb on the target"
    echo "           less [command]                  # pipe 'command' to 'less'"
    echo "           print-targets                   # List the build targets"
    echo "           report/build-report [targets]   # build targets and see if they compile without errors"
    echo "           --quite --no-interactive -q     # Don't ask questions"
    echo "           --build-dir [dir]               # Build Directory"
    echo "           --oneline                       # Compile and run quietly, print result in one line"
}


# Make a copy
args=("$@")

arg_pos=0
for arg in "${args[@]}"; do
    case $arg in
        clang|gcc|build|cmake-build*|build*)
            if [ -z "$build_dir"]; then
              build_dir=$(find . -name "*${args[$arg_pos]}*" -type d | head -n 1)
              unset "args[$arg_pos]"
              if [ ! -d "$build_dir" ]; then
                echo "Not a build directory: '${build_dir}'";
                exit 1;
              fi 
            fi
            ;;
        --build-dir|--build|-build-dir|-b)
            build_dir="${args[$(($arg_pos + 1))]}"
            if [ ! -d "$build_dir" ]; then
              build_dir=$(find . -name "*${build_dir}*" -type d | head -n 1)
              if [ ! -d "$build_dir" ]; then
                echo "Not a build directory: '${build_dir}'";
                exit 1;
              fi 
            fi
            unset "args[$arg_pos]"
            unset "args[$(($arg_pos + 1))]"
            arg_pos=$((arg_pos + 1))
            is_interactive=false
            ;;
        --no-interactive|--quite|-q)
            is_interactive=false
            unset "args[$arg_pos]"
            ;;
        oneline|one-line|--oneline|-oneline)
            is_oneline=true
            is_interactive=false
            should_clean=false
            unset "args[$arg_pos]"
            ;;
        --clean=false|--no-clean)
            should_clean=false;
            unset "args[$arg_pos]"
            ;;
        -r|less|-less|--less|-l|l)
            # Remove the string from the array by position
            unset "args[$arg_pos]"

            $0 --no-clean "${args[@]}" | less --RAW-CONTROL-CHARS --buffers=-1;
            exit $?
            ;;
        help|-help|--help)
            print_help;
            exit 0;
            ;;
        keep|watch)
            # Remove the string from the array by position
            unset "args[$arg_pos]"
            keep-running "${args[@]}";
            exit $?
            ;;
        print-targets|list|targets)
            unset "args[$arg_pos]"
            print_targets;
            exit;
            ;;
    esac
    arg_pos=$((arg_pos + 1))
done

if ! $is_oneline; then
  echo "---------${args[@]}";
fi

for arg in "${args[@]}"; do
  case "$arg" in
      analyze|scan-build)
          unset "args[0]"
          run analyze "${args[@]}";
          ;;
      lldb)
          unset "args[0]"
          run lldb "${args[@]}";
          ;;
      gdb)
          unset "args[0]"
          run gdb "${args[@]}";
          ;;
      build-report|report)
          unset "args[0]"
          build-report "${args[@]}";
          ;;
      "")
          # skip
          ;;
      *)
          # run the target
          run "${args[@]}";
          ;;
  esac
done
