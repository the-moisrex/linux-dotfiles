#!/usr/bin/env bash
set -euo pipefail

cur_file="$(basename "$0")"
verbose=false
files=()
exact=false
queries=()

show_help() {
  cat <<EOF_HELP
Usage: $cur_file [OPTIONS] [FILE...] TEST_NAME [TEST_NAME...]

Find and print original source for Google Test test cases.
By default, TEST_NAME is a prefix match, so "RouterTest" prints the whole suite
and "RouterTest.Basic" prints tests whose full name starts with that prefix.

TEST_NAME can be one of:
  Suite.Test
  Suite/Test
  Suite Test
  TEST(Suite, Test)
  TEST_F(Suite, Test)

Options:
  --help, -h     Display this help message and exit
  --exact        Match the given test name exactly
  --verbose, -v  Print searched files to stderr

Examples:
  $cur_file RouterTest.BasicGet
  $cur_file RouterTest RouterTest.Basic
  $cur_file --exact RouterTest.BasicGet
  $cur_file tests/router_test.cpp RouterTest BasicGet
EOF_HELP
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h)
      show_help
      exit 0
      ;;
    --verbose|-v)
      verbose=true
      shift
      ;;
    --exact)
      exact=true
      shift
      ;;
    -*)
      echo "Error: Unknown option $1" >&2
      exit 2
      ;;
    *)
      if [[ $# -gt 1 && -f "$1" ]]; then
        files+=("$1")
        shift
      else
        if [[ $# -eq 2 && "$1" != *.* && "$1" != */* && "$1" != TEST*\(* ]]; then
          queries+=("$1.$2")
          shift 2
        else
          queries+=("$1")
          shift
        fi
      fi
      ;;
  esac
done

if [[ ${#queries[@]} -eq 0 ]]; then
  echo "Error: Missing test name" >&2
  echo "Use '$cur_file --help' for usage information" >&2
  exit 2
fi

if [[ ${#files[@]} -eq 0 ]]; then
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Error: Not in a git repository; provide files explicitly" >&2
    exit 1
  fi
fi

PYTHON_VERBOSE="$verbose" \
PYTHON_EXACT="$exact" \
PYTHON_QUERY_COUNT="${#queries[@]}" \
python3 - "${queries[@]}" -- "${files[@]}" <<'PY'
import os
import re
import subprocess
import sys
from pathlib import Path

TEST_MACROS = (
    "TEST",
    "TEST_F",
    "TEST_P",
    "TYPED_TEST",
    "TYPED_TEST_P",
)
FILE_PATTERNS = (
    "*.c",
    "*.cc",
    "*.cpp",
    "*.cxx",
    "*.c++",
    "*.h",
    "*.hh",
    "*.hpp",
    "*.hxx",
    "*.ixx",
)

verbose = os.environ.get("PYTHON_VERBOSE") == "true"
exact = os.environ.get("PYTHON_EXACT") == "true"
query_count = int(os.environ["PYTHON_QUERY_COUNT"])
queries = [arg.strip() for arg in sys.argv[1:1 + query_count]]
files = sys.argv[2 + query_count:]


def parse_test_name(value):
    macro_match = re.match(
        r"^\s*(?:" + "|".join(TEST_MACROS) + r")\s*\(\s*([^,]+?)\s*,\s*([^,)]+?)\s*\)\s*$",
        value,
    )
    if macro_match:
        return macro_match.group(1).strip(), macro_match.group(2).strip()

    normalized = value.strip()
    if "/" in normalized:
        slash_parts = [part for part in normalized.split("/") if part]
        dotted_part = next((part for part in reversed(slash_parts) if "." in part), "")
        if dotted_part:
            normalized = dotted_part
        elif len(slash_parts) == 2:
            return slash_parts[0].strip(), slash_parts[1].strip()
    if "." in normalized:
        suite, name = normalized.rsplit(".", 1)
        return suite.strip(), name.strip()

    return normalized, ""


def display_query(suite, name):
    return suite if not name else f"{suite}.{name}"


def test_matches(suite, name, query_suite, query_name):
    full_name = f"{suite}.{name}"
    query = display_query(query_suite, query_name)
    if exact:
        if query_name:
            return suite == query_suite and name == query_name
        return suite == query_suite or full_name == query
    return full_name.startswith(query)


def run_git_grep(parsed_queries):
    commands = []
    for suite, name in parsed_queries:
        if name:
            commands.append(
                [
                    "git",
                    "grep",
                    "-l",
                    "-E",
                    rf"\b[A-Z_]*TEST[A-Z_]*[[:space:]]*\([[:space:]]*{re.escape(suite)}[[:space:]]*,[[:space:]]*{re.escape(name)}",
                    "--",
                    *FILE_PATTERNS,
                ]
            )
        commands.append(["git", "grep", "-l", suite, "--", *FILE_PATTERNS])
        if name:
            commands.append(["git", "grep", "-l", name, "--", *FILE_PATTERNS])

    if not commands:
        return []

    commands.append(["git", "ls-files", "--", *FILE_PATTERNS])
    seen = set()
    found = []
    for command in commands:
        proc = subprocess.run(command, capture_output=True, text=True)
        if proc.returncode not in (0, 1):
            continue
        for line in proc.stdout.splitlines():
            if line and line not in seen:
                seen.add(line)
                found.append(line)
    return found


def strip_comments_and_strings(text):
    result = []
    index = 0
    length = len(text)
    state = "code"
    raw_delim = ""
    while index < length:
        char = text[index]
        nxt = text[index + 1] if index + 1 < length else ""
        if state == "code":
            if char == "/" and nxt == "/":
                result.extend("  ")
                index += 2
                state = "line_comment"
            elif char == "/" and nxt == "*":
                result.extend("  ")
                index += 2
                state = "block_comment"
            elif char == "R" and nxt == '"':
                match = re.match(r'R"([^ ()\\\t\v\f\n\r]{0,16})\(', text[index:])
                if match:
                    raw_delim = ")" + match.group(1) + '"'
                    result.extend(" " * len(match.group(0)))
                    index += len(match.group(0))
                    state = "raw_string"
                else:
                    result.append(char)
                    index += 1
            elif char == '"':
                result.append(" ")
                index += 1
                state = "string"
            elif char == "'":
                result.append(" ")
                index += 1
                state = "char"
            else:
                result.append(char)
                index += 1
        elif state == "line_comment":
            result.append("\n" if char == "\n" else " ")
            index += 1
            if char == "\n":
                state = "code"
        elif state == "block_comment":
            if char == "*" and nxt == "/":
                result.extend("  ")
                index += 2
                state = "code"
            else:
                result.append("\n" if char == "\n" else " ")
                index += 1
        elif state == "string":
            if char == "\\":
                result.append(" ")
                if index + 1 < length:
                    result.append("\n" if nxt == "\n" else " ")
                index += 2
            else:
                result.append("\n" if char == "\n" else " ")
                index += 1
                if char == '"':
                    state = "code"
        elif state == "char":
            if char == "\\":
                result.append(" ")
                if index + 1 < length:
                    result.append("\n" if nxt == "\n" else " ")
                index += 2
            else:
                result.append("\n" if char == "\n" else " ")
                index += 1
                if char == "'":
                    state = "code"
        elif state == "raw_string":
            if text.startswith(raw_delim, index):
                result.extend(" " * len(raw_delim))
                index += len(raw_delim)
                state = "code"
            else:
                result.append("\n" if char == "\n" else " ")
                index += 1
    return "".join(result)


def skip_ws(text, index):
    while index < len(text) and text[index].isspace():
        index += 1
    return index


def find_matching(text, open_index, open_char, close_char):
    depth = 0
    index = open_index
    while index < len(text):
        if text[index] == open_char:
            depth += 1
        elif text[index] == close_char:
            depth -= 1
            if depth == 0:
                return index
        index += 1
    return -1


def split_top_level_args(arg_text):
    args = []
    start = 0
    depth = 0
    for index, char in enumerate(arg_text):
        if char in "(<[{":
            depth += 1
        elif char in ")>]}":
            depth = max(0, depth - 1)
        elif char == "," and depth == 0:
            args.append(arg_text[start:index].strip())
            start = index + 1
    args.append(arg_text[start:].strip())
    return args


def find_test_blocks(path, parsed_queries):
    original = Path(path).read_text(errors="replace")
    searchable = strip_comments_and_strings(original)
    macro_pattern = re.compile(r"\b(" + "|".join(TEST_MACROS) + r")\b")
    blocks = []

    for match in macro_pattern.finditer(searchable):
        index = skip_ws(searchable, match.end())
        if index >= len(searchable) or searchable[index] != "(":
            continue
        close_paren = find_matching(searchable, index, "(", ")")
        if close_paren == -1:
            continue
        args = split_top_level_args(searchable[index + 1:close_paren])
        if len(args) < 2:
            continue
        suite, name = args[0].strip(), args[1].strip()
        matched_query = next(
            (
                display_query(query_suite, query_name)
                for query_suite, query_name in parsed_queries
                if test_matches(suite, name, query_suite, query_name)
            ),
            "",
        )
        if not matched_query:
            continue

        body_start = skip_ws(searchable, close_paren + 1)
        if body_start >= len(searchable) or searchable[body_start] != "{":
            continue
        body_end = find_matching(searchable, body_start, "{", "}")
        if body_end == -1:
            continue

        start = match.start()
        while start > 0 and original[start - 1] in " \t":
            start -= 1

        end = body_end + 1
        while end < len(original) and original[end] in " \t\r\n":
            end += 1
        if end < len(original) and original[end] == ";":
            end += 1
        blocks.append((f"{suite}.{name}", matched_query, original[start:end].strip()))

    return blocks


parsed_queries = [parse_test_name(query) for query in queries if query.strip()]
if not files:
    files = run_git_grep(parsed_queries)

if verbose:
    print("Searching in files:", file=sys.stderr)
    for file in files:
        print(f"  {file}", file=sys.stderr)

seen = set()
found = []
for file in files:
    path = Path(file)
    if not path.is_file():
        print(f"Warning: File not found or not a regular file: {file}", file=sys.stderr)
        continue
    for test_full_name, matched_query, block in find_test_blocks(path, parsed_queries):
        if block not in seen:
            seen.add(block)
            found.append((file, test_full_name, matched_query, block))

if not found:
    rendered_queries = ", ".join(display_query(suite, name) for suite, name in parsed_queries)
    mode = "exact" if exact else "prefix"
    print(f"Error: No Google Test cases found for {mode} query: {rendered_queries}", file=sys.stderr)
    sys.exit(1)

for index, (file, test_full_name, matched_query, block) in enumerate(found):
    if index:
        print("\n")
    print(f"// File: {file}")
    print(f"// Test: {test_full_name}")
    if matched_query != test_full_name:
        print(f"// Matched: {matched_query}")
    print(block)
PY
