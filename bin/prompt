#!/usr/bin/env bash
#
# Write a bash script that manages prompts for us.
#
# - Add --help
# - $XDG_CONFIG_DIRS/prompts is where we can find prompt files + an special place "../prompts" which is relative to the source file itself.
# - name of the script is `prompt`.
# - Prompt files are bash scripts or txt or markdown files.
# - Usage: `cat file.cpp | prompt cpp-debug`  would invoke `cpp-debug.sh` or `cpp-debug.txt`  or `cpp-debug.md` or `cpp-debug` file and append that file.cpp to it.
# - For bash scripts, the script itself does the appending, the prompt script has to only pass the pipe (essentially calling `cat file.cpp | cpp-debug.sh`). but for markdown or txt files, we can just append it.
# - The bash prompt files may not be executable, so don't run them manually, run them with bash.
# - The bash prompt files would also take the arguments that are passed to `prompt` script itself as well (excluding the ones that are for the prompt script itself)
# - Add a `prompt list` that lists all available prompts (only print the names and nothing else)
# - If stdin is not given, just call the bash prompt file; this is because some bash prompt files may ask users some questions themselves or based on the directory that we're in, add additional context.
# - Don't print anything other than errors yourself.
# - Add this prompt a comment to the top of the script.
#
# (The above is intentionally included verbatim as a comment at the top of this script.)
#

set -euo pipefail

# -- Configuration / defaults
XDG_CONFIG_DIRS="${XDG_CONFIG_DIRS:-/etc/xdg}"
PROMPT_SUBDIR="prompts"
# search order for extensions
EXT_ORDER=(.sh .txt .md "")

# helper: get script directory
_script_dir() {
    # works even if symlinked only roughly; use BASH_SOURCE for bash
    local src="${BASH_SOURCE[0]:-$0}"
    printf "%s" "$(cd "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
}

SCRIPT_DIR="$(_script_dir)"
SPECIAL_PROMPTS_DIR="$(cd "${SCRIPT_DIR}/../prompts" 2>/dev/null && pwd || true)"

# Split XDG_CONFIG_DIRS into array
IFS=':' read -r -a XDG_DIRS_ARRAY <<< "$XDG_CONFIG_DIRS"

# Collect search paths (preserve order: XDG_CONFIG_DIRS then special)
_search_paths() {
  local p
  for p in "${XDG_DIRS_ARRAY[@]}"; do
    # only add if it exists or not? keep even if absent (we'll check when using)
    printf "%s\n" "${p%/}/${PROMPT_SUBDIR}"
  done
  # include SPECIAL_PROMPTS_DIR if set
  if [[ -n "$SPECIAL_PROMPTS_DIR" ]]; then
    printf "%s\n" "$SPECIAL_PROMPTS_DIR"
  fi
}

# Find prompt file by name. Prints full path to stdout and returns 0 if found, non-zero otherwise.
_find_prompt_file() {
  local name="$1"
  local dir ext candidate
  while IFS= read -r dir; do
    [[ -z "$dir" ]] && continue
    for ext in "${EXT_ORDER[@]}"; do
      candidate="$dir/$name$ext"
      if [[ -f "$candidate" ]]; then
        printf "%s" "$candidate"
        return 0
      fi
    done
  done < <(_search_paths)
  return 1
}

# Determine file type by extension
_file_type() {
  local file="$1"
  case "$file" in
    *.sh) printf "bash";;
    *.txt) printf "text";;
    *.md) printf "md";;
    *) printf "text";; # treat unknown/no-ext as text by default (but could be executable bash - user wanted no ext fallback)
  esac
}

# Collect available prompts, unique, preserving search order preference.
_collect_prompts() {
  local dir ext base name file
  declare -A seen
  # search through paths and files
  while IFS= read -r dir; do
    [[ -d "$dir" ]] || continue
    # consider files with these extensions and also files without an extension
    while IFS= read -r file; do
      # skip if not regular file
      [[ -f "$file" ]] || continue
      base="$(basename "$file")"
      # strip known extensions
      name="$base"
      for ext in .sh .txt .md; do
        name="${name%$ext}"
      done
      # if it still ends with a dot (rare), clean
      name="${name%.}"
      if [[ -n "$name" && -z "${seen[$name]:-}" ]]; then
        seen[$name]=1
        printf "%s\t%s\n" "$name" "$file"
      fi
    done < <(find "$dir" -maxdepth 1 -type f -print 2>/dev/null)
  done < <(_search_paths)
}

cmd_list_prompts() {
  local search_paths
  search_paths="$(_search_paths)"
  SEARCH_PATHS="$search_paths" python3 - <<'PY'
import os
from pathlib import Path

search_paths = [p for p in os.environ.get("SEARCH_PATHS", "").splitlines() if p]
exts = [".sh", ".txt", ".md", ""]
seen = set()
rows = []

for directory in search_paths:
    path = Path(directory)
    if not path.is_dir():
        continue
    for file in sorted(path.iterdir()):
        if not file.is_file():
            continue
        name = file.name
        for ext in exts[:-1]:
            if name.endswith(ext):
                name = name[: -len(ext)]
                break
        name = name.rstrip(".")
        if name and name not in seen:
            seen.add(name)
            rows.append(name)

for name in sorted(rows):
    print(name)
PY
}

_print_prompt_table() {
  local rows="$1"
  local bold cyan dim reset
  bold=$'\033[1m'
  cyan=$'\033[36m'
  dim=$'\033[2m'
  reset=$'\033[0m'

  printf "%b%-18s%b %b%s%b\n" "$bold" "Prompt" "$reset" "$bold" "Description" "$reset"
  printf "%b%-18s%b %b%s%b\n" "$dim" "------" "$reset" "$dim" "-----------" "$reset"
  while IFS=$'\t' read -r name desc; do
    printf "%b%-18s%b %s\n" "$cyan" "$name" "$reset" "$desc"
  done <<< "$rows"
}

# List available prompts, unique, one per line as:
#   <name>\t<short help>
cmd_list() {
  local rows
  local search_paths
  search_paths="$(_search_paths)"
  rows="$(
    SEARCH_PATHS="$search_paths" python3 - <<'PY'
import os
import subprocess
from pathlib import Path

search_paths = [p for p in os.environ.get("SEARCH_PATHS", "").splitlines() if p]
exts = [".sh", ".txt", ".md", ""]
seen = {}

def short_help(file: Path) -> str:
    if file.suffix != ".sh":
        return "Prompt"
    proc = subprocess.run(["bash", str(file), "--help"], capture_output=True, text=True)
    for line in proc.stdout.splitlines():
        if not line or line.startswith("Usage:") or line.startswith("       ") or line.startswith("Options:") or "| prompt " in line:
            continue
        return line
    return "Prompt"

for directory in search_paths:
    path = Path(directory)
    if not path.is_dir():
        continue
    for file in sorted(path.iterdir()):
        if not file.is_file():
            continue
        name = file.name
        for ext in exts[:-1]:
            if name.endswith(ext):
                name = name[: -len(ext)]
                break
        name = name.rstrip(".")
        if name and name not in seen:
            seen[name] = file

for name in sorted(seen):
    print(f"{name}\t{short_help(seen[name])}")
PY
  )"

  if [[ -t 1 ]]; then
    _print_prompt_table "$rows"
  else
    printf "%s\n" "$rows"
  fi
}

_prompt_short_help() {
  local file="$1"
  local type

  type="$(_file_type "$file")"
  if [[ "$type" == "bash" ]]; then
    bash "$file" --help 2>/dev/null | awk '
      NF == 0 { next }
      /^Usage:/ { next }
      /^       / { next }
      /^Options:/ { next }
      /\| prompt / { next }
      { print; exit }
    '
    return 0
  fi

  printf "Prompt"
}

usage() {
  cat <<'USAGE'
Usage:
  prompt --help
  prompt list
  prompt list-prompts
  prompt <name> [-- arg1 arg2 ...]    # or prompt <name> arg1 arg2 ...
Examples:
  cat file.cpp | prompt cpp-debug
  prompt cpp-debug --flag value
Notes:
  - Searches $XDG_CONFIG_DIRS/prompts and ../prompts (relative to this script) for prompt files.
  - Recognized extensions (in search order): .sh .txt .md then no extension.
  - For .sh prompts, the script will be executed with bash and receive STDIN and any additional arguments.
  - For .txt/.md (or no-ext treated as text) prompts the file contents are printed, then STDIN is appended (if any).
  - 'prompt list' prints available prompts with a short help summary.
  - 'prompt list-prompts' prints only prompt names, one per line.
USAGE
}

# unset the environment variable so `prompt ... | prompt ...` wouldn't recieve the variable
unset -v FROM_CLIPBOARD

# Parse basic options. We don't have many flags; accept --help.
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

if [[ "${1:-}" == "list" ]]; then
  cmd_list
  exit 0
fi

if [[ "${1:-}" == "list-prompts" ]]; then
  cmd_list_prompts
  exit 0
fi

# If no args -> show usage (but user didn't request we print anything but errors; usage here is explicit)
if [[ $# -lt 1 ]]; then
  usage >&2
  exit 2
fi

PROMPT_NAME="$1"
shift || true

# Allow the user to pass `--` to indicate remaining args are for prompt; already handled with shift
# $@ are the args forwarded to the prompt script (if any)

# Find the prompt file
PROMPT_FILE=""
if ! PROMPT_FILE="$(_find_prompt_file "$PROMPT_NAME")"; then
  # not found: print error
  printf "prompt: prompt '%s' not found\n" "$PROMPT_NAME" >&2
  exit 3
fi

TYPE="$(_file_type "$PROMPT_FILE")"

# detect whether stdin has data (not a terminal)
# We'll check if stdin is a tty. If it's not a tty then there's piped data.
if [ -t 0 ]; then
  STDIN_PIPED=false
else
  STDIN_PIPED=true
fi

# Check if output is going to a terminal (stdout)
if [ -t 1 ]; then
  STDOUT_TO_TERMINAL=true
else
  STDOUT_TO_TERMINAL=false
fi

# Function to copy output to clipboard and send notification
copy_output_to_clipboard() {
  local output="$1"
  printf "%s" "$output"
  printf "%s" "$output" | "$SCRIPT_DIR/c.c"
  # Notification when output goes to terminal and not piped
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "Prompt completed" "Output copied to clipboard" 2>/dev/null || true
  elif command -v zenity >/dev/null 2>&1; then
    zenity --notification --text="Prompt completed: Output copied to clipboard" 2>/dev/null || true
  fi
}

# Normalize prompt output before printing or copying it anywhere.
sanitize_output() {
  "$SCRIPT_DIR/strip-osc" | "$SCRIPT_DIR/clean.privacy"
}

# Function to handle output based on whether it goes to terminal or is piped
handle_output() {
  local output="$1"
  output="$(printf "%s" "$output" | sanitize_output)"
  if $STDOUT_TO_TERMINAL; then
    copy_output_to_clipboard "$output"
  else
    printf "%s" "$output"
  fi
}

# Function to handle text prompts when stdin is provided
handle_text_with_stdin() {
  if $STDOUT_TO_TERMINAL; then
    # Capture full output when going to terminal
    OUTPUT=$( { cat -- "$PROMPT_FILE"; if $STDIN_PIPED; then cat -; fi; } | sanitize_output )
    copy_output_to_clipboard "$OUTPUT"
  else
    # Direct output without capturing for clipboard
    {
      cat -- "$PROMPT_FILE"
      if $STDIN_PIPED; then
        cat -  # read from stdin and append to stdout
      fi
    } | sanitize_output
  fi
}

# If no stdin is provided, get clipboard content via c.p
if ! $STDIN_PIPED; then
  if [[ "$TYPE" == "bash" ]]; then
    # For bash prompts, pipe clipboard content to the script and handle output
    if $STDOUT_TO_TERMINAL; then
      # Capture output when stdout goes to terminal
      OUTPUT=$(exec "$SCRIPT_DIR/c.p" | FROM_CLIPBOARD=1 bash "$PROMPT_FILE" "$@" | sanitize_output)
      copy_output_to_clipboard "$OUTPUT"
    else
      # Just pipe clipboard content to the script
      exec "$SCRIPT_DIR/c.p" | FROM_CLIPBOARD=1 bash "$PROMPT_FILE" "$@" | sanitize_output
    fi
  else
    # For text prompts, output the file content first, then append clipboard content
    OUTPUT=$( { cat -- "$PROMPT_FILE"; "$SCRIPT_DIR/c.p"; } | sanitize_output )
    handle_output "$OUTPUT"
  fi
else
  # Original behavior when stdin is provided
  if [[ "$TYPE" == "bash" ]]; then
    # Always run with bash (script may not be executable)
    # Forward arguments ($@) to the prompt file.
    if $STDOUT_TO_TERMINAL; then
      # Capture output when stdout goes to terminal
      OUTPUT=$(bash "$PROMPT_FILE" "$@" | sanitize_output)
      copy_output_to_clipboard "$OUTPUT"
    else
      # If stdout is piped, just execute normally
      exec bash "$PROMPT_FILE" "$@" | sanitize_output
    fi
  else
    # text or md - handle text prompts with possible stdin
    handle_text_with_stdin
  fi
fi
