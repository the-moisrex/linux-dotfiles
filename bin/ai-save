#!/usr/bin/env bash

# Default variables
TARGET_DIR="$HOME/Documents/AI-Chats"
DOMAIN_URL="https://gapgpt.app"
MODE="SYNC"
TARGET_TOKEN=""

# Help message
print_help() {
    echo "Usage: $0 [OPTIONS]"
    echo "Sync AI chats to local markdown files and commit them to Git."
    echo ""
    echo "Options:"
    echo "  --help           Show this help message"
    echo "  --dir <path>     Set target directory (default: \$HOME/Documents/AI-Chats)"
    echo "  --recreate       Recreate markdown files from local .ai cache without fetching APIs"
    echo "  --overwrite      Check for broken chats (missing messages) and securely replace them"
    echo "  --remove <token> Remove a specific chat by its token"
    echo "  --reload <token> Remove a specific chat locally and download it again from scratch"
}

# Parse arguments
while [[ "$#" -gt 0 ]]; do
    case $1 in
        --help) print_help; exit 0 ;;
        --dir) TARGET_DIR="$2"; shift 2 ;;
        --recreate) MODE="RECREATE"; shift 1 ;;
        --overwrite) MODE="OVERWRITE"; shift 1 ;;
        --remove) MODE="REMOVE"; TARGET_TOKEN="$2"; shift 2 ;;
        --reload) MODE="RELOAD"; TARGET_TOKEN="$2"; shift 2 ;;
        *) echo "Unknown parameter passed: $1"; exit 1 ;;
    esac
done

# Dependency check
for cmd in curl jq git; do
    if ! command -v "$cmd" &> /dev/null; then
        echo "Error: '$cmd' is required but not installed."
        exit 1
    fi
done

# Setup directories
mkdir -p "$TARGET_DIR/.ai/chat-meta"
mkdir -p "$TARGET_DIR/.ai/chat-content"
cd "$TARGET_DIR" || exit 1

# Initialize git if it doesn't exist
if [ ! -d ".git" ]; then
    git init
    echo "Initialized empty Git repository."
fi

AUTH_FILE=".ai/auth.json"
PROJECT_CACHE=".ai/projects.json"

# Validate Authentication setup
if [ ! -f "$AUTH_FILE" ]; then
    echo "Error: Authentication file not found at $TARGET_DIR/$AUTH_FILE"
    echo "Please create it with the following structure:"
    echo '{ "Authorization": "Bearer TOKEN", "Cookie": "cookie=value; ..." }'
    exit 1
fi

AUTH_HEADER=$(jq -r '.Authorization // empty' "$AUTH_FILE")
COOKIE_HEADER=$(jq -r '.Cookie // empty' "$AUTH_FILE")

# Helper function to fetch from API and ignore invalid JSON or HTTP errors
fetch_api() {
    local url="$1"
    local http_code
    local body
    local tmp_body
    
    tmp_body=$(mktemp)

    # We do not retry on network error, as requested
    http_code=$(curl -s -o "$tmp_body" -w "%{http_code}" --compressed "$url" \
        -H "User-Agent: Mozilla/5.0 (X11; Linux x86_64; rv:148.0) Gecko/20100101 Firefox/148.0" \
        -H "Accept: application/json, text/plain, */*" \
        -H "Authorization: $AUTH_HEADER" \
        -H "Cookie: $COOKIE_HEADER")

    body=$(cat "$tmp_body")
    rm -f "$tmp_body"

    # Verify that request was successful (ignore 4xx, 5xx, or network failure codes)
    if [[ "$http_code" -ge 400 || "$http_code" == "000" ]]; then
        echo "INVALID_JSON"
        return 1
    fi

    # Ignore invalid JSON blocks
    if ! jq empty <<< "$body" 2>/dev/null; then
        echo "INVALID_JSON"
        return 1
    fi
    echo "$body"
}

# Resolve folder name from Project Token using local cache
get_folder_name() {
    local p_token="$1"
    if [[ "$p_token" == "null" || -z "$p_token" || ! -f "$PROJECT_CACHE" ]]; then
        echo "Uncategorized"
    else
        local name
        name=$(jq -r --arg t "$p_token" '.results[] | select(.token == $t) | .name' "$PROJECT_CACHE")
        if [[ -z "$name" || "$name" == "null" ]]; then
            echo "Uncategorized"
        else
            echo "$name"
        fi
    fi
}

# Generate deterministic file path based on chat metadata
calculate_expected_path() {
    local item="$1"
    local p_token=$(jq -r '.project_token // empty' <<< "$item")
    local title=$(jq -r '.title // "Untitled"' <<< "$item")
    local created=$(jq -r '.created_at // empty' <<< "$item")

    local folder=$(get_folder_name "$p_token")
    
    # Sanitize title: remove bad characters and trailing dots
    local safe_title=$(echo "$title" | sed 's/[<>:"/\\|?*]//g' | sed 's/\.*$//')
    
    # Format date to YYYY-MM-DD_HH-MM
    local safe_date=$(echo "$created" | cut -c1-16 | tr 'T' '_' | tr ':' '-')

    echo "${folder}/${safe_date}_${safe_title}.md"
}

# Parse JSONs and output a Markdown formatted chat
generate_md() {
    local token="$1"
    local expected_path="$2"
    local meta_path=".ai/chat-meta/${token}.json"
    local content_path=".ai/chat-content/${token}.json"

    if [[ ! -f "$meta_path" || ! -f "$content_path" ]]; then
        return
    fi

    local folder=$(dirname "$expected_path")
    mkdir -p "$folder"

    local tmp_md=$(mktemp)

    local title=$(jq -r '.title // "Untitled"' "$meta_path")
    echo "# $title" > "$tmp_md"
    echo "" >> "$tmp_md"

    # Iterate over chat messages gracefully preventing bash syntax errors
    local msg_count=$(jq '.messages | length' "$content_path" 2>/dev/null)
    if [[ -z "$msg_count" || "$msg_count" == "null" ]]; then
        msg_count=0
    fi
    
    for (( i=0; i<msg_count; i++ )); do
        local text=$(jq -r ".messages[$i].text // empty" "$content_path")

        if [[ -n "$text" ]]; then
            echo "## User" >> "$tmp_md"
            echo "$text" >> "$tmp_md"
            echo "" >> "$tmp_md"
        fi

        local resp_count=$(jq ".messages[$i].response | length" "$content_path")
        if [[ $resp_count -gt 0 ]]; then
            echo "## Assistant" >> "$tmp_md"
            for (( j=0; j<resp_count; j++ )); do
                local type=$(jq -r ".messages[$i].response[$j].type // empty" "$content_path")
                local content=$(jq -r ".messages[$i].response[$j].content // empty" "$content_path")

                if [[ "$type" == "reasoning" ]]; then
                    echo "<details><summary>Reasoning</summary>" >> "$tmp_md"
                    echo "" >> "$tmp_md"
                    echo "$content" >> "$tmp_md"
                    echo "" >> "$tmp_md"
                    echo "</details>" >> "$tmp_md"
                    echo "" >> "$tmp_md"
                else
                    echo "$content" >> "$tmp_md"
                    echo "" >> "$tmp_md"
                fi
            done
        fi
    done

    # Extract metadata for the footer
    local model=$(jq -r '.model // "Unknown"' "$meta_path")
    local created=$(jq -r '.created_at // "Unknown"' "$meta_path")
    local last_msg=$(jq -r '.last_message_created_at // "Unknown"' "$meta_path")
    local p_token=$(jq -r '.project_token // "None"' "$meta_path")

    echo "---" >> "$tmp_md"
    echo "**Model:** \`$model\`  " >> "$tmp_md"
    echo "**Created At:** \`$created\`  " >> "$tmp_md"
    echo "**Last Message:** \`$last_msg\`  " >> "$tmp_md"
    echo "**Chat Token:** \`$token\`  " >> "$tmp_md"
    echo "**Project Token:** \`$p_token\`" >> "$tmp_md"

    # Move generated file to location
    mv "$tmp_md" "$expected_path"
    
    # Keep track of file location to handle future renames/moves easily
    echo "$expected_path" > ".ai/chat-meta/${token}.path"
}

# Assess single chat item, fetch missing/updated data, and generate markdown
process_chat_item() {
    local item="$1"
    local token=$(jq -r '.token' <<< "$item")

    local meta_path=".ai/chat-meta/${token}.json"
    local path_tracker=".ai/chat-meta/${token}.path"

    local needs_update=0
    local fetch_content=0

    # 1. Determine if a content fetch is required
    if [[ ! -f "$meta_path" ]]; then
        needs_update=1
        fetch_content=1
    else
        local old_last=$(jq -r '.last_message_created_at // empty' "$meta_path")
        local new_last=$(jq -r '.last_message_created_at // empty' <<< "$item")
        if [[ "$old_last" != "$new_last" ]]; then
            needs_update=1
            fetch_content=1
        fi
    fi

    # 2. Check if a folder or file-name move occurred
    local expected_path=$(calculate_expected_path "$item")
    local old_path=""
    if [[ -f "$path_tracker" ]]; then
        old_path=$(cat "$path_tracker")
    fi

    if [[ -n "$old_path" && "$old_path" != "$expected_path" ]]; then
        # File moved or was renamed, clean up old structure
        if [[ -f "$old_path" ]]; then
            rm -f "$old_path"
            rmdir "$(dirname "$old_path")" 2>/dev/null || true # safely remove empty folder
        fi
        needs_update=1
    elif [[ ! -f "$expected_path" ]]; then
        # Mark as missing
        needs_update=1
    fi

    if [[ "$needs_update" -eq 0 ]]; then
        return
    fi

    echo "- Syncing chat: $token"

    if [[ "$fetch_content" -eq 1 ]]; then
        local content_res
        content_res=$(fetch_api "$DOMAIN_URL/api/v1/get_chat/token/${token}")
        if [[ "$content_res" == "INVALID_JSON" ]]; then
            echo "  -> Failed to fetch content API, skipping."
            return 1
        fi
        
        # Verify content has messages array to prevent caching error payloads
        local is_valid_array
        is_valid_array=$(jq '.messages | type == "array"' <<< "$content_res" 2>/dev/null)
        if [[ "$is_valid_array" != "true" ]]; then
            echo "  -> API returned invalid chat data (missing messages array), skipping to prevent corruption."
            return 1
        fi

        echo "$content_res" > ".ai/chat-content/${token}.json"
        echo "$item" > "$meta_path"
    fi

    generate_md "$token" "$expected_path"
}

# Completely remove local chat structures
remove_chat() {
    local token="$1"
    if [[ -z "$token" ]]; then
        echo "Error: Token cannot be empty."
        return 1
    fi
    echo "Removing chat: $token"
    
    local path_tracker=".ai/chat-meta/${token}.path"
    if [[ -f "$path_tracker" ]]; then
        local old_path=$(cat "$path_tracker")
        if [[ -n "$old_path" && -f "$old_path" ]]; then
            rm -f "$old_path"
            rmdir "$(dirname "$old_path")" 2>/dev/null || true
        fi
        rm -f "$path_tracker"
    fi
    
    rm -f ".ai/chat-meta/${token}.json"
    rm -f ".ai/chat-content/${token}.json"
    
    echo "Chat $token has been completely removed."
}

# Remove existing contents locally and redownload entirely from scratch
reload_chat() {
    local token="$1"
    if [[ -z "$token" ]]; then
        echo "Error: Token cannot be empty."
        return 1
    fi
    echo "Reloading chat: $token"
    
    local meta_path=".ai/chat-meta/${token}.json"
    if [[ ! -f "$meta_path" ]]; then
        echo "Error: Metadata for $token not found locally. Cannot reconstruct markdown without it."
        echo "Please run a normal sync without parameters to discover and fetch this chat."
        return 1
    fi
    
    local item=$(cat "$meta_path")
    
    # 1. Clean up old markdown file
    local path_tracker=".ai/chat-meta/${token}.path"
    if [[ -f "$path_tracker" ]]; then
        local old_path=$(cat "$path_tracker")
        if [[ -n "$old_path" && -f "$old_path" ]]; then
            rm -f "$old_path"
            rmdir "$(dirname "$old_path")" 2>/dev/null || true
        fi
    fi
    
    # 2. Remove old content block
    rm -f ".ai/chat-content/${token}.json"
    
    # 3. Fetch fresh content from scratch
    local content_res
    content_res=$(fetch_api "$DOMAIN_URL/api/v1/get_chat/token/${token}")
    if [[ "$content_res" == "INVALID_JSON" ]]; then
        echo "  -> Failed to fetch content API. Reload aborted."
        return 1
    fi
    
    # Make sure we didn't fetch an API error message
    local is_valid_array
    is_valid_array=$(jq '.messages | type == "array"' <<< "$content_res" 2>/dev/null)
    if [[ "$is_valid_array" != "true" ]]; then
        echo "  -> Fetched content does not contain messages. Reload aborted."
        return 1
    fi

    echo "$content_res" > ".ai/chat-content/${token}.json"
    
    # 4. Generate freshly baked markdown
    local expected_path=$(calculate_expected_path "$item")
    generate_md "$token" "$expected_path"
    
    echo "Chat $token reloaded successfully."
}

# --- MODE EXECUTION ---

if [[ "$MODE" == "RECREATE" ]]; then
    echo "Recreating all markdown files from local JSON cache..."
    for meta_file in .ai/chat-meta/*.json; do
        if [[ -f "$meta_file" ]]; then
            token=$(basename "$meta_file" .json)
            item=$(cat "$meta_file")
            expected_path=$(calculate_expected_path "$item")
            
            old_path=""
            if [[ -f ".ai/chat-meta/${token}.path" ]]; then
                old_path=$(cat ".ai/chat-meta/${token}.path")
            fi
            
            if [[ -n "$old_path" && "$old_path" != "$expected_path" && -f "$old_path" ]]; then
                rm -f "$old_path"
                rmdir "$(dirname "$old_path")" 2>/dev/null || true
            fi
            
            generate_md "$token" "$expected_path"
        fi
    done
    echo "Recreation complete."
    exit 0

elif [[ "$MODE" == "OVERWRITE" ]]; then
    echo "Checking for chats with missing content to overwrite them..."
    for meta_file in .ai/chat-meta/*.json; do
        if [[ -f "$meta_file" ]]; then
            token=$(basename "$meta_file" .json)
            content_file=".ai/chat-content/${token}.json"
            
            is_broken=0
            if [[ ! -f "$content_file" ]]; then
                is_broken=1
            else
                # Find structurally broken caches (caused by the old bug)
                is_valid_array=$(jq '.messages | type == "array"' "$content_file" 2>/dev/null)
                if [[ "$is_valid_array" != "true" ]]; then
                    is_broken=1
                fi
            fi
            
            if [[ "$is_broken" -eq 1 ]]; then
                echo "- Broken chat detected: $token. Overwriting..."
                reload_chat "$token"
            fi
        fi
    done
    # Falls through to Git commit process below

elif [[ "$MODE" == "REMOVE" ]]; then
    remove_chat "$TARGET_TOKEN"

elif [[ "$MODE" == "RELOAD" ]]; then
    reload_chat "$TARGET_TOKEN"

else
    # SYNC MODE
    echo "Fetching projects..."
    proj_res=$(fetch_api "$DOMAIN_URL/api/v1/projects")
    if [[ "$proj_res" != "INVALID_JSON" ]]; then
        echo "$proj_res" > "$PROJECT_CACHE"
    fi

    if [[ -f "$PROJECT_CACHE" ]]; then
        proj_count=$(jq '.results | length' "$PROJECT_CACHE")
        for (( i=0; i<proj_count; i++ )); do
            p_token=$(jq -r ".results[$i].token" "$PROJECT_CACHE")
            p_name=$(jq -r ".results[$i].name" "$PROJECT_CACHE")
            echo "Processing folder: $p_name"

            {
                chat_list_res=$(fetch_api "$DOMAIN_URL/api/v1/projects/$p_token")
                if [[ "$chat_list_res" != "INVALID_JSON" ]]; then 
                    chat_count=$(jq '.chats | length' <<< "$chat_list_res")
                    for (( j=0; j<chat_count; j++ )); do
                        chat_item=$(jq -c ".chats[$j]" <<< "$chat_list_res")
                        process_chat_item "$chat_item"
                    done
                fi
            } &
        done
        wait
    fi

    echo "Processing Uncategorized chats..."
    url="$DOMAIN_URL/api/v1/chat_list?limit=40&offset=0"
    while [[ -n "$url" && "$url" != "null" ]]; do
        list_res=$(fetch_api "$url")
        if [[ "$list_res" == "INVALID_JSON" ]]; then break; fi

        count=$(jq '.results | length' <<< "$list_res")
        if [[ "$count" -eq 0 ]]; then break; fi

        for (( j=0; j<count; j++ )); do
            chat_item=$(jq -c ".results[$j]" <<< "$list_res")
            process_chat_item "$chat_item"
        done

        # Fetch next page url if it exists
        url=$(jq -r '.next // empty' <<< "$list_res")
        if [ ! -z "$url" ]; then
            echo "  Next: $url"
        fi
    done
fi

# --- COMMIT ---
echo "Registering git state..."
if ! grep -q ".ai/auth.json" "$TARGET_DIR/.gitignore"; then
    echo ".ai/auth.json" >> "$TARGET_DIR/.gitignore";
fi
git add .
git status
if git status --porcelain | grep -q "^"; then
    git commit -m "Auto-sync $(date)"
    echo "Changes successfully committed to Git."
else
    echo "No new updates found. Everything is up to date."
fi
