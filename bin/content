#!/bin/bash

SCRIPT_DIR=$(dirname "$(realpath "$0")")

GLOBAL_HTML=(
    -r link
    -r noscript
    -r .carousel-stage
    -r .news_code
    -r .short_link_box
    -r .ita_application
    -r .noprint
    -r .author_tools
    -r .news_tools
    -r .mobile_adv
    -r style
    -r script
    -r .copyright
    -r "[type=hidden]"
    -r head
    -r .date_mob
    -r .hidden-ms
    -r .hidden-sm
    -r .hidden-md
    -r .hidden-xs
    -r .hidden
    -r .logo
    -r .logo_xs
    -r .nav_share_to
    -r .nav_services
    -r .modal
    -r footer
    -r .news_commont_header
    #-r "a[href=#]"
    -r .news_like_google
    -r .home_link
    -r .news_home_link
    -r .news_newsletter_link
    -r .news_comment_header
    -r .sn_linkdin
    -r .sn_googleplus
    -r .sn_telegram
    -r .sn_list
    -r .social_nets
    -r .share_to_container
    -r svg
    -r .btn_copy_script
    -r .adv_col_news_page
    -r .send_friend_bot
    #-r "#menu"
    #-r "#submenu"
    -r .icon-search
    -r button
    -r .submenu
    #-r "\"header nav\""
    #-r "\"header ul\""
    -r .barcode
    #-r "a[href*=\"bale.ir\"]"
    #-r "a[href*=\"rubika.ir\"]"
    #-r "icon-*"
    -r .tools-menu
    -r select
    -r .languages-menu
    -r .tooltip-link
    -r .related_news
    -r .tags_title
    -r .tags_container
    -r .sp_line
    -r .error
    -r .like_shortLink_report_share
    -r .lazyload
    -r i.fa
    -r span.fa
    -r .box-download
    -r .share-news
    -r .box-number-news
    -r .content-related
    -r .suggested-news-cover
    -r .main-comment-form-news
    -r form
    -r .social-icon-news
    -r .tags_container_news
    -r .share-box-news
    -r .video-download
    -r video
    -r "'[style*=\"display:none\"]'"
    -r "'[style*=\"display: none\"]'"
    -r .rating-stars
    -r "'article nav'"
    -r noscript
    -r .comm_title_box
    -r .comments_container
    -r .comments_item
    -r .news_link_item
    -r .video-tool-box
    -r .path_bottom_body_video
    -r .videojs-main-container
    -r .bg-related-news
    -r .bread_crump
    -r .video_news_adv
    -r .download_full_album
    -r .videojs_main
    -r .nav-background
    -r .logo-background
    -r .no-js
    -r .js-hidden
    -r .list-unstyled
    -r .livePage
    -r .newsrelated_media
    -r .no-print

    -r aside
    -r iframe
    -r picture
    -r source
    # -r 'figure figcaption'
    -r .newsletter
    -r .subscribe
    -r .paywall
    -r .sticky
    -r .advertisement
    -r .ad
    -r .promo
    -r .recommended
    -r .recommendations
    -r .outbrain
    -r .taboola
    -r .cookie
    -r .breadcrumbs
    -r .breadcrumb
    -r .author
    -r .byline
    -r .caption
    -r .gallery
    -r .lightbox
)

HTML="${GLOBAL_HTML[*]}"

# Function to display help information
show_help() {
    echo "Usage: $0 [options] <websites...> [-- command [args...]]"
    echo
    echo "Options:"
    echo "  --help          Display this help message"
    echo "  --verbose       Enable verbose output"
    echo "  --no-filter     Disable filters"
    echo "  --no-transform  Disable transforming to plain text"
    echo "  --no-curl       Don't expect a URL, expect the HTML"
    echo "  --print-url     Print the URL at the end"
    echo "  --asfile        Pass the aggregated output via file to the command after --"
    echo "  --all-at-once   Pass output of ALL urls at once to the command (Default is per URL)"
    echo "  --pool, -p      Set max parallel tasks (default: 5)"
    echo "  --format [FMT]  Set pandoc output format (default: ${PANDOC_FORMAT})"
    echo
    echo "Example usage:"
    echo "  $ c.p | content --asfile -- gnome-text-editor -n"
    echo "  $ content --asfile -- gnome-text-editor"
    echo "  $ content -- zenity --text-info"
    echo "  $ content --asfile --format odt -- xdg-open"
    ech
    echo
    echo "Pandoc Output Formats:"
    pandoc --list-output-formats | tr '\n' ','
    echo
}

# Parse command-line arguments
VERBOSE=false
NO_FILTER=false
NO_TRANSFORM=false
NO_CURL=false
ASFILE=false
ALL_AT_ONCE=false
POOL_SIZE=5
WEBSITE=""
URL=""
declare -a COMMAND=()
args="$@"
flags=()
URLs=()
IS_CHILD=false
PRINT_URL=false
PANDOC_FORMAT="markdown_github"


sync_parallel_output() {
    local sites=("$@")
    local outputs=()
    local pids=()
    local active=0

    for site in "${sites[@]}"; do
        [ -z "$site" ] && continue
        out=$(mktemp -q --suffix=".md")
        outputs+=("$out")
        
        # Run child process in background
        "$0" "${flags[@]}" --pandoc-format "$PANDOC_FORMAT" --child "$site" >"$out" 2>/dev/null &
        pids+=($!)
        
        # Limit parallelism
        ((active++))
        if (( active >= POOL_SIZE )); then
            wait -n
            ((active--))
        fi
    done

    # Wait for each job in order, then print or run command
    for i in "${!pids[@]}"; do
        wait "${pids[$i]}" 2>/dev/null || true
        
        # If command exists and we process PER URL
        if [ ${#COMMAND[@]} -gt 0 ] && ! $ALL_AT_ONCE; then
            if $ASFILE; then
                cat "${outputs[$i]}" | "$SCRIPT_DIR/asfile" -- "${COMMAND[@]}" &
            else
                cat "${outputs[$i]}" | "${COMMAND[@]}" &
            fi
        else
            cat "${outputs[$i]}"
        fi
        rm -f "${outputs[$i]}"
    done
}


while [[ $# -gt 0 ]]; do
    case $1 in
        --help)
            show_help
            exit 0
        ;;
        --child)
            IS_CHILD=true
            shift
        ;;
        --verbose|-v)
            VERBOSE=true
            flags+=("--verbose")
            shift
        ;;
        --print-url)
            VERBOSE=true
            PRINT_URL=true
            shift
        ;;
        --nofilter|-nofilter|no-filter|-no-filter|--no-filter)
            NO_FILTER=true
            flags+=("--no-filter")
            shift
        ;;
        --nocurl|-nocurl|no-curl|-no-curl|--no-curl)
            NO_CURL=true
            flags+=("--no-curl")
            shift
        ;;
        --notransform|no-trans|-no-trans|--no-trans|--notrans|notrans|-notrans|-notransform|no-transform|-no-transform|--no-transform)
            NO_TRANSFORM=true
            flags+=("--no-trans")
            shift
        ;;
        --asfile|-asfile|asfile|--as-file|-as-file|as-file)
            ASFILE=true
            shift
        ;;
        --all-at-once|-a)
            ALL_AT_ONCE=true
            shift
        ;;
        --pool|-p)
            POOL_SIZE="$2"
            shift 2
        ;;
        --website|-website|website|site|--site|-site)
            shift
            flags+=("--website" "$1")
            WEBSITE="$1"
            shift
        ;;
        --format|-format|--pandoc-format)
            shift
            PANDOC_FORMAT="$1"
            if ! pandoc --list-output-format | grep --quiet "$PANDOC_FORMAT" >/dev/null; then
                echo "Pandoc Format unknown: $1" >&2;
                exit 1;
            fi
            shift
            ;;
        --)
            shift
            COMMAND=("$@")
            break
        ;;
        *)
            if [ -z "$URL" ]; then
                URL="$1"
            else
                URLs+=("$1")
            fi
            shift
        ;;
    esac
done

# If parent process, handle inputs and parallelization
if ! $IS_CHILD; then
    # Add initial URL to the URLs list if set
    if [ -n "$URL" ]; then
        URLs=("$URL" "${URLs[@]}")
    fi

    # Read from stdin or clipboard if no URLs provided
    if [ ${#URLs[@]} -eq 0 ]; then
        if [ ! -t 0 ]; then
            # Read from pipeline/stdin
            mapfile -t URLs < /dev/stdin
        else
            # Stdin is empty/terminal, fallback to c.p
            if [ -f "$SCRIPT_DIR/c.p" ]; then
                mapfile -t URLs < <("$SCRIPT_DIR/c.p")
            elif hash c.p 2>/dev/null; then
                mapfile -t URLs < <(c.p)
            fi
        fi
    fi
    
    # Process the URLs
    process_all() {
        if [ ${#URLs[@]} -gt 0 ]; then
            sync_parallel_output "${URLs[@]}"
        fi
    }

    # Handle output routing
    if [ ${#COMMAND[@]} -gt 0 ]; then
        if $ALL_AT_ONCE; then
            # Pass aggregated output to a single command execution
            if $ASFILE; then
                process_all | "$SCRIPT_DIR/asfile" -- "${COMMAND[@]}"
            else
                process_all | "${COMMAND[@]}"
            fi
        else
            # Outputs passed per-URL directly in sync_parallel_output
            process_all
        fi
    else
        process_all
    fi
    exit $?
fi


# ----------------------------------------
# Child process logic starts here
# ----------------------------------------

if ! $NO_CURL; then
    # Default curl options with a user-agent to mimic a browser
    cookie_file=$(mktemp --suffix .cookies.txt --dry-run)
    trap 'rm -f "$cookie_file"' EXIT
    CURL_OPTIONS="-sqL --insecure --cookie-jar '$cookie_file' --user-agent 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/58.0.3029.110 Safari/537.3'"
    WEBSITE=$(node -e "console.log(new URL('${URL}').hostname.replace(/^www\\./, ''))" )
    if [ -z "$WEBSITE" ]; then
        echo "Error: No website specified in URL ${URL}"
        show_help
        exit 1
    elif $VERBOSE; then
        echo "Website: $WEBSITE"
    fi
fi


# Configure website-specific settings
CURL_COMMANDS=("curl $CURL_OPTIONS \"$URL\"")
TRANSFORMS=(
    "pandoc -f html -t ${PANDOC_FORMAT} --strip-comments --listings --quiet --markdown-headings=atx --wrap=none"
    # "sed 's/\\[\\]//g'"
)
case $WEBSITE in
    irna.ir)
        sec_cookies=$(curl -sqL "$URL" | grep "return {'value_v1" | awk '{print "var res = (function() {" $0 "})(); console.log(`__arcsjs=${res.value_v1}; __arcsjsc=${res.value}`)"}' | node -)
        CURL_COMMANDS=(
            "curl $CURL_OPTIONS -H 'Cookie: $sec_cookies' \"$URL\""
        )
        FILTERS=(
            "htmlq -wp article $HTML -r nav -r .tags -r .item-code -r .item-foot-nav -r .item-nav -r .item-footer -r .item-boxes -r .area-item -r figure.item-img"
        )
        ;;
    ilna.ir)
        FILTERS=(
            "htmlq -w article $HTML -r .primary_files"
        )
        ;;
    iribnews.ir)
        FILTERS=(
            "htmlq -wp main $HTML -r .sp_ln_news -r .mob_lang -r .desktop-view -r .link_row -r .news_print_link -r .news_link_item -r .news_commont_header -r .media_comments -r .video_top_news -r .media_last_body_main -r .video_content -r .video_body -r .photo_tags_container -r .tab_most -r .videojs-main-container -r .news_nav"
        )
        ;;
    mehrnews.com)
        FILTERS=(
            "htmlq -w article $HTML -r .header-sharing -r .item-sharing -r .short-link-container -r .tooltip-link -r .item-boxes -r section.box.tags -r .item-code -r .item-footer -r .item-nav -r .related-items -r '.item-summary figure'"
        )
        ;;
    snn.ir)
        FILTERS=(
            "htmlq -wp $HTML -r .news_toolbar -r .related-container -r .sepehr-key-related-news -r .sar_ticker"
        )
        ;;
    yjc.ir)
        FILTERS=(
            "htmlq -wp .news-box $HTML -r .comments-pager-news -r .row_mv_photo_newspage"
        )
        ;;
    tabnak.ir)
        FILTERS=(
            "htmlq -wp main $HTML -r .top_title -r .adv_news -r .top_mrg -r .tab_home_inner -r .top_mrg -r .tab_most_body -r .tabs-container -r .linear_news -r .Htag -r .stitle_box -r .pollBox -r '#parentPolls' -r .row_selected_tag -r .news_id_c -r .border-mobile -r .advNews -r .visible-xs -r .visible-sm -r .visible-md -r .visible-lg -r .visible-ms -r .wrapper -r .row_tag -r .image_btn -r .news_navbox -r .phNewsShareRow -r .phNewsTagsRow -r .srvHeadBox -r .phNewsToolBox -r .phBreadCrumbUl -r .phNewsCmBg"
        )
        ;;
    tasnimnews.ir)
        FILTERS=(
            "htmlq -wp 'article.single-news' $HTML -r .service -r .footer -r .blog-details-share -r .hideTag"
        )
        ;;
    farsnews.ir)
        FILTERS=(
            "htmlq -wp $HTML -r aside -r div[name=list] -r header -r .text-center -r bdi.font-default -r .items-center -r hr -r .text-gray-500 -r img -r .absolute -r .text-primary-500 -r .text-gray-600 -r .select-none"
        )
        ;;
    khabarfoori.com)
        FILTERS=(
            "htmlq -wp article $HTML"
        )
        ;;
    eslahatnews.com)
        FILTERS=(
            "htmlq -wp 'main.news_body_bg' $HTML -r .breadcrumb_news -r .news_toolbar -r .news_left_toolbar -r .time -r .second_news_toolbar -r .authorBox -r .page_text -r .sub_toolbar -r .news_id_c -r .news_pdate_t -r .news_pdate_d -r .zoom-tools -r .shortLink-sec -r .mobile_share_link"
        )
        ;;
    aviny.com)
        FILTERS=(
            "htmlq -wp '#body-inner' $HTML -r .nav-responsive-wrapper -r '#header' -r '#nav' -r footer -r .messages-wrapper -r table -r .row"
        )
        ;;
    sepahnews.ir)
        FILTERS=(
            "htmlq -wp article $HTML -r .item-header -r .item-title -r .item-nav -r .item-foot-nav -r .item-footer -r .item-boxes -r .item-sharing -r .short-link-container -r .tags -r .tags_container -r .related-items -r .item-code -r .item-author -r .item-date -r .rating-stars -r .breadcrumb -r .item-img -r .item-body -r .item-text -r .summary -r .introtext"
        )
        ;;
    diroozban.ir)
        FILTERS=(
            "htmlq '#news_article_content, .lead, .primary_files'"
        )
        ;;
    rouydad24.ir|roydad24.ir)
        FILTERS=(
            "htmlq -r 'section.box31-cover' -r 'div.article.relDesktop' -r 'div.article.relBg' -r 'div.tags_container' -r 'div[id^=\"pos-article-\"]' -r 'div.yn-bnr' 'article.news-article'"
        )
        ;;
    virgool.io)
        FILTERS=("htmlq -wp -r '#navbar' -r '#app-portal' -r .is-divider-right -r .color-gray-900 -r aside -r button.no-hover .vrgl-col, p, h1")
        ;;
    digiato.ir|digiato.com)
        FILTERS=("htmlq -wp '.articlePost, .dailyNewsPageHead h1, .dailyNewsPageHead p' -r .notfluidbox -r .app__download--link -r .app__download--leftside -r .app__download")
        ;;
    rt.com)
        FILTERS=("htmlq -wp '.article' $HTML -r .article__listing -r .article__ya-recommendations -r .article__social-wrapper -r .article__tags-trends -r .article__invitation -r .article__share -r .mediaplayer -r .copyright-symbol -r .article__breadcrumbs -r .article__tag -r .read-more -r .article__comments -r .article__cover")
        ;;
    bbc.com|bbc)
        FILTERS=(
            "htmlq -wp 'main, article, [data-component=\"text-block\"]' $HTML -r header -r footer -r nav -r aside -r .bbc-1n4f7g4 -r script -r style -r .bbc-mj7j1g"
        )
        ;;
    reuters.com|reuters)
        FILTERS=(
            "htmlq -wp article $HTML -r header -r footer -r nav -r .related-content -r .social -r .byline"
        )
        ;;
    *)
        FILTERS=(
            "htmlq -wp $HTML"
        )
        if $VERBOSE; then
            echo "Website '$WEBSITE' not specifically configured. Using default settings."
        fi
        ;;
esac

# Build the pipeline
if $NO_CURL; then
    PIPELINE="cat -"
else
    PIPELINE="( "
    for i in "${!CURL_COMMANDS[@]}"; do
        PIPELINE+="${CURL_COMMANDS[$i]}"
        if [ $i -lt $((${#CURL_COMMANDS[@]} - 1)) ]; then
            PIPELINE+="; "
        else
            PIPELINE+=" "
        fi
    done
    PIPELINE+=")"
fi
if ! $NO_FILTER; then
    for filter in "${FILTERS[@]}"; do
        PIPELINE+=" | $filter"
    done
fi

if ! $NO_TRANSFORM; then
    for TRANSFORM in "${TRANSFORMS[@]}"; do
        PIPELINE+=" | $TRANSFORM"
    done
fi

# Display the pipeline if verbose mode is enabled
if $VERBOSE; then
    echo "Executing: $PIPELINE"
fi

# Execute the pipeline
eval "$PIPELINE"
if $PRINT_URL; then
    echo
    echo "$URL"
fi
