#!/bin/bash

SCRIPT_DIR=$(dirname "$0")

GLOBAL_HTML=(
    -r .news_code
    -r .short_link_box
    -r .ita_application
    -r .noprint
    -r .author_tools
    -r .news_tools
    -r .mobile_adv
    -r style
    -r script
    -r .copyright
    -r "[type=hidden]"
    -r head
    -r .date_mob
    -r .hidden-ms
    -r .hidden-sm
    -r .hidden-md
    -r .hidden-xs
    -r .hidden
    -r .logo
    -r .logo_xs
    -r .nav_share_to
    -r .nav_services
    -r .modal
    -r footer
    -r .news_commont_header
    #-r "a[href=#]"
    -r .news_like_google
    -r .home_link
    -r .news_home_link
    -r .news_newsletter_link
    -r .news_comment_header
    -r .sn_linkdin
    -r .sn_googleplus
    -r .sn_telegram
    -r .sn_list
    -r .social_nets
    -r .share_to_container
    -r svg
    -r .btn_copy_script
    -r .adv_col_news_page
    -r .send_friend_bot
    #-r "#menu"
    #-r "#submenu"
    -r .icon-search
    -r button
    -r .submenu
    #-r "\"header nav\""
    #-r "\"header ul\""
    -r .barcode
    #-r "a[href*=\"bale.ir\"]"
    #-r "a[href*=\"rubika.ir\"]"
    #-r "icon-*"
    -r .tools-menu
    -r select
    -r .languages-menu
    -r .tooltip-link
    -r .related_news
    -r .tags_title
    -r .tags_container
    -r .sp_line
    -r .error
    -r .like_shortLink_report_share
    -r .lazyload
    -r i.fa
    -r span.fa
    -r .box-download
    -r .share-news
    -r .box-number-news
    -r .content-related
    -r .suggested-news-cover
    -r .main-comment-form-news
    -r form
    -r .social-icon-news
    -r .tags_container_news
    -r .share-box-news
    -r .video-download
    -r video
    -r "'[style*=\"display:none\"]'"
    -r "'[style*=\"display: none\"]'"
    -r .rating-stars
    -r "'article nav'"
    -r noscript
)

HTML="${GLOBAL_HTML[*]}"

# Function to display help information
show_help() {
    echo "Usage: $0 [options] <websites...>"
    echo
    echo "Options:"
    echo "  --help          Display this help message"
    echo "  --verbose       Enable verbose output"
    echo "  --no-filter     Disable filters"
    echo "  --no-transform  Disable transforming to plain text"
    echo "  --no-curl       Don't expect a URL, expect the HTML"
}

# Parse command-line arguments
VERBOSE=false
NO_FILTER=false
NO_TRANSFORM=false
NO_CURL=false
WEBSITE=""
URL=""
COMMAND=""

args="$@"
while [[ $# -gt 0 ]]; do
    case $1 in
        --help)
            show_help
            exit 0
        ;;
        --verbose|-v)
            VERBOSE=true
            shift
        ;;
        --nofilter|-nofilter|no-filter|-no-filter|--no-filter)
            NO_FILTER=true
            shift
        ;;
        --nocurl|-nocurl|no-curl|-no-curl|--no-curl)
            NO_CURL=true
            shift
        ;;
        --notransform|no-trans|-no-trans|--no-trans|--notrans|notrans|-notrans|-notransform|no-transform|-no-transform|--no-transform)
            NO_TRANSFORM=true
            shift
        ;;
        --website|-website|website|site|--site|-site)
            shift
            WEBSITE="$1"
            shift
        ;;
        *)
            if [ -z "$URL" ]; then
                URL="$1"
            else
                if $VERBOSE; then
                    $0 --verbose "$URL"
                else
                    $0 "$URL"
                fi
                URL="$1"
            fi
            shift
        ;;
    esac
done

if [ -z "$URL" ]; then
    cat - | xargs -l $0 $args
    exit $?
fi

if ! $NO_CURL; then
    # Default curl options with a user-agent to mimic a browser
    cookie_file=$(mktemp --suffix .cookies.txt --dry-run)
    trap 'rm -f "$cookie_file"' EXIT
    CURL_OPTIONS="-sqL --cookie-jar '$cookie_file' --user-agent 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/58.0.3029.110 Safari/537.3'"
    WEBSITE=$(node -e "console.log(new URL('${URL}').hostname.replace(/^www\\./, ''))" )
    if [ -z "$WEBSITE" ]; then
        echo "Error: No website specified in URL ${URL}"
        show_help
        exit 1
    elif $VERBOSE; then
        echo "Website: $WEBSITE"
    fi
fi


# Configure website-specific settings
CURL_COMMANDS=("curl $CURL_OPTIONS \"$URL\"")
TRANSFORMS=("pandoc -f html -t plain")
case $WEBSITE in
    irna.ir)
        sec_cookies=$(curl -sqL $URL | grep "return {'value_v1" | awk '{print "var res = (function() {" $0 "})(); console.log(`__arcsjs=${res.value_v1}; __arcsjsc=${res.value}`)"}' | node -)
        CURL_COMMANDS=(
            "curl $CURL_OPTIONS -H 'Cookie: $sec_cookies' $URL"
        )
        FILTERS=(
            "htmlq -wp article $HTML -r nav -r .tags -r .item-code -r .item-foot-nav -r .item-nav -r .item-footer -r .item-boxes"
        )
        ;;
    ilna.ir)
        FILTERS=(
            "htmlq -w article $HTML"
        )
        ;;
    iribnews.ir)
        FILTERS=(
            "htmlq -w main $HTML -r .sp_ln_news -r .mob_lang -r .desktop-view -r .link_row -r .news_print_link -r .news_link_item -r .news_commont_header"
        )
        ;;
    mehrnews.com)
        FILTERS=(
            "htmlq -w article $HTML -r .header-sharing -r .item-sharing -r .short-link-container -r .tooltip-link -r .item-boxes -r section.box.tags -r .item-code -r .item-footer -r .item-nav -r .related-items"
        )
        ;;
    snn.ir)
        FILTERS=(
            "htmlq -wp main $HTML -r .news_toolbar -r .related-container -r .sepehr-key-related-news"
        )
        ;;
    yjc.ir)
        FILTERS=(
            "htmlq -wp .news-box $HTML"
        )
        ;;
    tabnak.ir)
        FILTERS=(
            "htmlq -wp main $HTML -r .top_title -r .adv_news -r .top_mrg -r .tab_home_inner -r .top_title -r .tab_most_body -r .tabs-container -r .linear_news -r .Htag -r .stitle_box -r .pollBox -r '#parentPolls' -r .row_selected_tag -r .news_id_c"
        )
        ;;
    tasnimnews.ir)
        FILTERS=(
            "htmlq -wp 'article.single-news' $HTML -r .service -r .footer -r .blog-details-share -r .hideTag"
        )
        ;;
    *)
        FILTERS=(
            "htmlq -wp $HTML"
        )
        if $VERBOSE; then
            echo "Website '$WEBSITE' not specifically configured. Using default settings."
        fi
        ;;
esac

# Build the pipeline
if $NO_CURL; then
    PIPELINE="cat -"
else
    PIPELINE="( "
    for i in "${!CURL_COMMANDS[@]}"; do
        PIPELINE+="${CURL_COMMANDS[$i]}"
        if [ $i -lt $((${#CURL_COMMANDS[@]} - 1)) ]; then
            PIPELINE+="; "
        else
            PIPELINE+=" "
        fi
    done
    PIPELINE+=")"
fi
if ! $NO_FILTER; then
    for filter in "${FILTERS[@]}"; do
        PIPELINE+=" | $filter"
    done
    # PIPELINE+=" | grep -vE \"${EXCLUDE_REGEX}\""
fi

if ! $NO_TRANSFORM; then
    for TRANSFORM in "${TRANSFORMS[@]}"; do
        PIPELINE+=" | $TRANSFORM"
    done
fi

# Display the pipeline if verbose mode is enabled
if $VERBOSE; then
    echo "Executing: $PIPELINE"
fi

# Execute the pipeline
eval "$PIPELINE"
