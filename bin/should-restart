#!/bin/bash

# Color definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

if ! command -v lsof >/dev/null; then
    echo -e "${RED}Error: lsof command not found.${NC}"
    echo "Install it using your package manager (e.g., # pacman -S lsof)"
    exit 1
fi

echo -e "${BLUE}=== System Restart & Library Update Checker ===${NC}"
echo -e "Checking if you should reboot the system or restart applications...\n"

get_latest_kernel() {
    # Extract versions from all kernels in /boot, then sort naturally to find the highest
    for f in /boot/vmlinuz* /boot/vmlinuz-*; do
        if [[ -f "$f" ]]; then
            file "$f" | awk '{for(i=1;i<=NF;i++) if($i=="version") print $(i+1)}'
        fi
    done | sort -V | tail -n 1
}

rc=1
# Find deleted libraries still loaded in memory
libs=$(lsof -n +c 0 2> /dev/null | awk '/DEL.*lib/ {print $0}')

if [[ -n "$libs" ]]; then
    echo -e "${YELLOW}[!] Library changes detected. Application restarts required.${NC}"
    
    apps=$(awk '{print $1}' <<< "$libs" | sort -u | paste -sd, - | sed 's/,/, /g')
    if [[ -n "$apps" ]]; then
        echo -e "\n${BLUE}Software requiring a restart:${NC}"
        echo -e "  $apps"
    fi
    
    clibs=$(awk '{print $NF}' <<< "$libs" | sort -u)
    if [[ -n "$clibs" ]]; then
        echo -e "\n${BLUE}Changed Libraries (files deleted but in use):${NC}"
        awk '{print "  - " $0}' <<< "$clibs"
    fi
    echo ""
    rc=0
else
    echo -e "${GREEN}[✓] No library changes detected.${NC}"
fi

active_kernel=$(uname -r)
latest_kernel=$(get_latest_kernel)

if [[ -n "$latest_kernel" ]] && [[ "$active_kernel" != "$latest_kernel" ]]; then
    # Sometimes uname -r has suffixes that file output doesn't, so do a loose match check
    if [[ "$active_kernel" != *"$latest_kernel"* ]]; then
        echo -e "${RED}[!] KERNEL UPDATE DETECTED: Reboot required!${NC}"
        echo -e "  Running kernel: ${YELLOW}$active_kernel${NC}"
        echo -e "  Latest installed: ${YELLOW}$latest_kernel${NC}"
        rc=0
    else
        echo -e "${GREEN}[✓] No kernel changes detected.${NC} (Running: $active_kernel)"
    fi
else
    echo -e "${GREEN}[✓] No kernel changes detected.${NC} (Running: $active_kernel)"
fi

exit $rc
