#!/bin/bash

if [[ "$1" == "--help" ]]; then
    echo "Usage: $0 [input_string]"
    echo "       command | $0"
    echo "Extracts paths of existing files (along with line and column numbers) from the input."
    exit 0
fi

# Read from stdin if available, otherwise read from arguments
if [ ! -t 0 ]; then
    input=$(cat)
else
    input="$*"
fi

# Extract file paths with optional line and column numbers
echo "$input" | grep -oE '([a-zA-Z0-9_./-]+):[0-9]+(:[0-9]+)?' | while read -r match; do
    # Extract just the file path part (everything before the first colon)
    filepath="${match%%:*}"
    
    # Only print if the file actually exists on the filesystem
    if [[ -f "$filepath" ]]; then
        echo "$match"
    fi
done
