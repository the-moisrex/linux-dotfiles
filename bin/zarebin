#!/bin/bash

# Zarebin Search Engine Script
# Usage: zarebin <search_query> [options]

set -e

SCRIPT_DIR="$(dirname "$0")"

# Default values
QUERY=""
PAGE=1
LIMIT=10
DEVICE="d"
ENABLE_SMART_ANSWERS="true"
VERBOSE=false
PRINT_JSON=false
OUTPUT_FILE=""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

show_help() {
    cat << EOF
Usage: $0 [options] <search_query>

Search the Zarebin search engine.

Arguments:
  search_query      The search query (required)

Options:
  -p, --page NUM    Page number (default: 1)
  -l, --limit NUM   Number of results per page (default: 10)
  -d, --device TYPE Device type: d (desktop), m (mobile) (default: d)
  --json            Output as JSON instead of plain text
  -o, --output FILE Write output to file
  -v, --verbose     Enable verbose output
  -h, --help        Display this help message

Examples:
  $0 "test"
  $0 "technology" --page 2 --limit 20
  $0 "news" --json --verbose
  $0 "search term" -p 1 -l 50 -d m

API URL:
  https://zarebin.ir/gse/api/search?q=<query>&pl=0&page=<page>&ldi=0&user_device=<device>&limit=<limit>&enable_smart_answers=true

EOF
}

# Parse command-line arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            show_help
            exit 0
        ;;
        -v|--verbose)
            VERBOSE=true
            shift
        ;;
        --json)
            PRINT_JSON=true
            shift
        ;;
        -o|--output)
            OUTPUT_FILE="$2"
            shift 2
        ;;
        -p|--page)
            PAGE="$2"
            shift 2
        ;;
        -l|--limit)
            LIMIT="$2"
            shift 2
        ;;
        -d|--device)
            DEVICE="$2"
            shift 2
        ;;
        *)
            if [ -z "$QUERY" ]; then
                QUERY="$1"
            else
                echo -e "${RED}Error: Unexpected argument '$1'${NC}" >&2
                show_help
                exit 1
            fi
            shift
        ;;
    esac
done

# Validate required arguments
if [ -z "$QUERY" ]; then
    echo -e "${RED}Error: Search query is required${NC}" >&2
    show_help
    exit 1
fi

# URL encode the query using Python for proper UTF-8 encoding
ENCODED_QUERY=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$QUERY', encoding='utf-8'))")

# Build the API URL
API_URL="https://zarebin.ir/gse/api/search?q=${ENCODED_QUERY}&pl=0&page=${PAGE}&ldi=0&user_device=${DEVICE}&limit=${LIMIT}&enable_smart_answers=${ENABLE_SMART_ANSWERS}"

if $VERBOSE; then
    echo -e "${BLUE}API URL:${NC} $API_URL"
fi

# Function to fetch and process results
fetch_results() {
    local url="$1"
    local cookie_file
    cookie_file=$(mktemp --suffix .cookies.txt --dry-run)
    
    # Fetch the API response
    local response
    response=$(curl -sqL --insecure \
        --cookie-jar "$cookie_file" \
        --user-agent 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/58.0.3029.110 Safari/537.3' \
    "$url" 2>/dev/null)
    
    rm -f "$cookie_file"
    
    echo "$response"
}

# Function to extract and display results in plain text
display_plain_text() {
    local json="$1"
    
    # Extract results using jq if available
    if command -v jq &> /dev/null; then
        echo "$json" | jq -r '
            .result.all.results.webs[] |
            "Title: \(.title // "N/A")\nURL: \(.web_link // "N/A")\nDomain: \(.domain // "N/A")\nSnippet: \(.description // "N/A")\n---"
        ' 2>/dev/null || echo "$json"
    else
        # Fallback: basic text extraction using grep/sed
        echo "$json" | grep -oP '"title"\s*:\s*"\K[^"]+' | head -20
        echo ""
        echo "$json" | grep -oP '"web_link"\s*:\s*"\K[^"]+' | head -20
    fi
}

# Function to display results in a formatted table
display_table() {
    local json="$1"
    
    if command -v jq &> /dev/null; then
        echo "$json" | jq -r '
            .result.all.results.webs[] |
            "\(.title // "N/A" | @base64)\t\(.web_link // "N/A" | @base64)"
        ' 2>/dev/null | while IFS=$'\t' read -r title url; do
            echo -e "${BLUE}$(echo "$title" | base64 -d)${NC}"
            echo -e "  ${GREEN}$(echo "$url" | base64 -d)${NC}"
            echo ""
        done
    else
        display_plain_text "$json"
    fi
}

# Fetch results
if $VERBOSE; then
    echo -e "${GREEN}Fetching results...${NC}"
fi

JSON_RESPONSE=$(fetch_results "$API_URL")

# Check if we got a response
if [ -z "$JSON_RESPONSE" ]; then
    echo -e "${RED}Error: Failed to fetch results from Zarebin${NC}" >&2
    exit 1
fi

# Output results
if [ -n "$OUTPUT_FILE" ]; then
    if $PRINT_JSON; then
        echo "$JSON_RESPONSE" > "$OUTPUT_FILE"
    else
        display_table "$JSON_RESPONSE" > "$OUTPUT_FILE"
    fi
else
    if $PRINT_JSON; then
        echo "$JSON_RESPONSE"
    else
        display_table "$JSON_RESPONSE"
    fi
fi

exit 0
