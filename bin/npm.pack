#!/usr/bin/env bash
set -uo pipefail

# Default version for packages specified via list files or direct arguments
VERSION="latest"

# Variables to store input types
declare -a INPUT_PACKAGE_LIST_FILES=() # Stores paths to files containing package lists
PACKAGE_JSON_PATH=""                 # Stores path to a specific package.json or directory
RECURSIVE_PATH=""                    # Stores path for recursive scanning

# --- Helper functions ---

# Print usage and exit
usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS] [PACKAGE_LIST_FILES...]

Pack npm packages using 'npm pack'.

Input Methods (choose only one primary method):
  -f, --file <file>       Read package names (one per line) from FILE.
                          Multiple -f options are allowed, or provide files as positional
                          arguments. The -v/--version option applies to these packages.
  -p, --package-json <path>  Read 'dependencies', 'devDependencies', 'peerDependencies',
                          and 'optionalDependencies' from a package.json file or a
                          directory containing one. Versions specified in package.json
                          are used; -v/--version is ignored in this mode.
  -r, --recursive <dir>   Recursively find package.json files within <dir> and pack
                          all their dependencies. Versions specified in package.json
                          are used; -v/--version is ignored in this mode.

Options:
  -v, --version VERSION   Use a specific version, a semver range, or "latest"
                          for packages specified via -f or positional arguments.
                          Examples: "1.2.3", ">=2.0.0 <3.0.0", "latest".
                          Default: "latest".
  -h, --help              Show this help message and exit.

The script runs 'npm pack <package>@<version>' for each identified package.
Requires 'jq' for processing package.json files (-p and -r options).
EOF
    exit 0
}

# Packs a single package specification (e.g., "lodash@^4.0.0" or "express@latest")
pack_package_spec() {
    local pkg_spec="$1"
    echo "Packing: $pkg_spec"
    if npm pack "$pkg_spec"; then
        echo "→ Success"
    else
        echo "→ Failed (exit code $?)" >&2
    fi
    echo
}

# Packs dependencies from a given package.json file
pack_dependencies_from_package_json() {
    local json_file="$1"

    if [[ ! -f "$json_file" ]]; then
        echo "Error: package.json file not found: '$json_file'" >&2
        return 1
    fi

    echo "--- Processing dependencies from: $json_file ---"

    if ! command -v jq &> /dev/null; then
        echo "Warning: 'jq' is not installed. Cannot parse package.json for dependencies." >&2
        echo "Please install 'jq' to use -p or -r options (e.g., apt install jq, brew install jq)." >&2
        return 1
    fi

    # Extract all dependency types (dependencies, devDependencies, peerDependencies, optionalDependencies)
    # and format them as "package_name@version_spec"
    local dependencies_string
    dependencies_string=$(jq -r '
        .dependencies // {} +
        .devDependencies // {} +
        .peerDependencies // {} +
        .optionalDependencies // {}
        | to_entries[]
        | select(.key != null and .value != null) # Ensure key and value exist
        | .key + "@" + .value
    ' "$json_file" 2>/dev/null) # Redirect jq errors to /dev/null for cleaner output

    if [[ -z "$dependencies_string" ]]; then
        echo "No dependencies found in $json_file."
        return 0
    fi

    # Loop through each dependency specification and pack it
    while IFS= read -r spec_line; do
        # Trim leading/trailing whitespace
        spec_line="$(echo "$spec_line" | xargs)"
        [[ -z "$spec_line" ]] && continue # Skip empty lines after trim
        pack_package_spec "$spec_line"
    done <<< "$dependencies_string"
}


# --- Option Parsing ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        -v|--version)
            if [[ -z "${2:-}" ]]; then
                echo "Error: --version requires a value" >&2
                exit 1
            fi
            VERSION="$2"
            shift 2
            ;;
        -f|--file)
            if [[ -z "${2:-}" ]]; then
                echo "Error: --file requires a value" >&2
                exit 1
            fi
            INPUT_PACKAGE_LIST_FILES+=("$2")
            shift 2
            ;;
        -p|--package-json)
            if [[ -z "${2:-}" ]]; then
                echo "Error: --package-json requires a value" >&2
                exit 1
            fi
            # Check for conflicting input methods
            if [[ -n "$PACKAGE_JSON_PATH" || -n "$RECURSIVE_PATH" || ${#INPUT_PACKAGE_LIST_FILES[@]} -gt 0 ]]; then
                echo "Error: Cannot combine -p with -f, -r, or positional arguments." >&2
                usage >&2
                exit 1
            fi
            PACKAGE_JSON_PATH="$2"
            shift 2
            ;;
        -r|--recursive)
            if [[ -z "${2:-}" ]]; then
                echo "Error: --recursive requires a value" >&2
                exit 1
            fi
            # Check for conflicting input methods
            if [[ -n "$PACKAGE_JSON_PATH" || -n "$RECURSIVE_PATH" || ${#INPUT_PACKAGE_LIST_FILES[@]} -gt 0 ]]; then
                echo "Error: Cannot combine -r with -f, -p, or positional arguments." >&2
                usage >&2
                exit 1
            fi
            RECURSIVE_PATH="$2"
            shift 2
            ;;
        -h|--help)
            usage
            ;;
        --) # End of options
            shift
            # Remaining arguments are treated as package list files
            INPUT_PACKAGE_LIST_FILES+=("$@")
            break
            ;;
        -*) # Unknown option
            echo "Error: Unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
        *)  # Positional arguments are treated as package list files
            INPUT_PACKAGE_LIST_FILES+=("$1")
            shift
            ;;
    esac
done

# Ensure at least one input method is specified
if [[ -z "$PACKAGE_JSON_PATH" && -z "$RECURSIVE_PATH" && ${#INPUT_PACKAGE_LIST_FILES[@]} -eq 0 ]]; then
    echo "Error: No input method specified. Please use -f, -p, -r, or provide package list files as arguments." >&2
    usage >&2
    exit 1
fi

# --- Main Execution Logic ---

# Case 1: Recursive scan for package.json files
if [[ -n "$RECURSIVE_PATH" ]]; then
    if [[ ! -d "$RECURSIVE_PATH" ]]; then
        echo "Error: Recursive path '$RECURSIVE_PATH' is not a directory." >&2
        exit 1
    fi
    echo "Scanning '$RECURSIVE_PATH' recursively for package.json files..."
    # Use -print0 and read -r -d $'\0' for robust handling of filenames with spaces
    find "$RECURSIVE_PATH" -type f -name 'package.json' -print0 | while IFS= read -r -d $'\0' json_file; do
        pack_dependencies_from_package_json "$json_file"
    done
    exit 0
fi

# Case 2: Specific package.json file or directory
if [[ -n "$PACKAGE_JSON_PATH" ]]; then
    target_json_file="$PACKAGE_JSON_PATH"
    if [[ -d "$PACKAGE_JSON_PATH" ]]; then
        # If a directory is provided, look for package.json inside it
        target_json_file="$PACKAGE_JSON_PATH/package.json"
    fi
    pack_dependencies_from_package_json "$target_json_file"
    exit 0
fi

# Case 3: Package list files (default or via -f)
# This block is executed only if -p or -r were not used and exited
for file in "${INPUT_PACKAGE_LIST_FILES[@]}"; do
    if [[ ! -f "$file" ]]; then
        echo "Warning: Package list file '$file' not found, skipping." >&2
        continue
    fi

    echo "=== Processing packages from: $file ==="
    while IFS= read -r pkg || [[ -n "$pkg" ]]; do
        # Trim whitespace, skip empty lines and lines starting with #
        pkg="$(echo "$pkg" | xargs)"
        [[ -z "$pkg" || "$pkg" == \#* ]] && continue

        # Construct npm pack argument: <package>@<version>
        spec="${pkg}@${VERSION}"
        pack_package_spec "$spec"
    done < "$file"
done
