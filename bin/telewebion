#!/bin/bash

if [[ "$1" == "--help" ]]; then
    echo "Usage: $0 [search_term | --list | list | episode_url | episode_id]"
    echo ""
    echo "Options:"
    echo "  --help    Show this help message"
    echo "  --list    List all channel descriptors"
    echo "  list      List all channel descriptors"
    echo ""
    echo "Examples:"
    echo "  $0 --list                                          # List all channel descriptors"
    echo "  $0 tv1                                             # Play channel with descriptor 'tv1'"
    echo "  $0 شبکه 1                                          # Search for channel with 'شبکه 1' in name/description"
    echo "  $0 sport                                           # Search for channels containing 'sport'"
    echo "  $0 https://telewebion.ir/episode/0xXXXXXXXX        # Play a specific episode by URL"
    echo "  $0 0xXXXXXXXX                                      # Play a specific episode by ID"
    exit 0
fi

# Check if input is a telewebion episode URL or an episode ID (starts with 0x)
if [[ "$1" == *"telewebion.ir/episode/"* || "$1" == 0x* ]]; then
    if [[ "$1" == *"telewebion.ir/episode/"* ]]; then
        episode_id="${1##*/}"
    else
        episode_id="$1"
    fi
    
    echo "Fetching metadata for episode $episode_id..."
    api_response=$(curl -sqL "https://gateway.telewebion.ir/kandoo/episode/getEpisodeDetail/?EpisodeId=${episode_id}")
    
    # Extract the channel descriptor from the API response
    descriptor=$(echo "$api_response" | jq -r '.body.queryEpisode[0].channel.descriptor')
    
    if [[ -z "$descriptor" || "$descriptor" == "null" ]]; then
        echo "Error: Could not determine channel descriptor for episode $episode_id."
        exit 1
    fi
    
    playlist_url="https://cdna.telewebion.ir/${descriptor}/episode/${episode_id}/playlist.m3u8"
    
    echo "Channel: $descriptor"
    echo "Playlist: $playlist_url"
    
    mpv \
    --profile=fast \
    --force-window=immediate \
    --ytdl=no \
    --hwdec=auto \
    --icc-profile-auto \
    --force-seekable=yes \
    --cache=yes \
    "$playlist_url"
    
    exit 0
fi

metadata=$(curl -sqL "https://gateway.telewebion.ir/kandoo/channel/getChannelsList/")

# Handle --list or list option
if [[ "$1" == "--list" || "$1" == "list" ]]; then
    echo "$metadata" | jq -r '.body.queryChannel[].descriptor'
    exit 0
fi

# Set search term (if provided)
search_term="$1"

# Create temporary playlist file
playlist=$(mktemp --suffix .playlist.m3u8)

# Generate playlist content
echo "#EXTM3U" > "$playlist"
# echo "#EXT-X-VERSION:6" >> "$playlist"
# echo "#EXT-X-PLAYLIST-TYPE:EVENT" >> "$playlist"
# echo "$metadata" | jq -r '.body.queryChannel[] | "#EXT-X-STREAM-INF:NAME=\"\(.name)\",BANDWIDTH=2560000\nhttps://ncdn.telewebion.ir/\(.descriptor)/live/playlist.m3u8"' >> "$playlist"
echo "$metadata" | jq -r '.body.queryChannel[] | "#EXTINF:0,\(.descriptor) \(.name)\nhttps://ncdn.telewebion.ir/\(.descriptor)/live/playlist.m3u8"' >> "$playlist"

# If search term provided, find matching channel index
if [ -n "$search_term" ]; then
    index=$(echo "$metadata" | jq -r --arg search "$search_term" '
        .body.queryChannel | to_entries |
        map(select( [.value.descriptor, .value.name, .value.name_english, .value.description] | join(" ") | contains($search) )) |
    .[0].key')
    
    if [ -z "$index" ]; then
        echo "No channels found matching '$search_term'"
        rm -f "$playlist"
        exit 1
    fi
fi

# Play the playlist
args=(
    --profile=fast
    --force-window=immediate
    --ytdl=no
    --hwdec=auto
    --icc-profile-auto
    # --script-opt=ytdl_hook-all_formats=yes
    # --hls-bitrate=max
    --force-seekable=yes
    --cache=yes
    --hls-bitrate=min             # Or specify a rate
    --demuxer-max-bytes=32MiB     # Lower from default
    --demuxer-readahead-secs=2    # Keep the forward buffer very small
    # --demuxer-max-bytes=128MiB
    # --demuxer-max-back-bytes=512MiB
    # --demuxer-lavf-format=hls # Force the standard HLS demuxer
    # --demuxer-lavf-analyzeduration=0.1
    # --demuxer-lavf-probesize=131072
    --untimed=yes          # Helps with live stream latency
    --hls-bitrate=2000000  # Caps auto-selection around the 720p/1080p standard tracks
    "$playlist"
)
if [ -n "$search_term" ]; then
    echo "Index $index of the playlist $playlist";
    echo "mpv --playlist-start=$index ${args[@]}";
    mpv --playlist-start="$index" "${args[@]}";
else
    echo "Playlist: $playlist";
    echo "mpv ${args[@]}";
    mpv "${args[@]}";
fi

# Clean up temporary file
rm -f "$playlist"
