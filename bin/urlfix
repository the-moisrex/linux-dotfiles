#!/bin/bash

value="href"
CLEAN=false
file=$(mktemp --suffix .urlfix.js)
echo "try {" >> "$file"
for url in "$@"; do
    case $url in
        --help|-h)
            echo "Fix the URL using WHATWG URL Parser. Requires nodejs.";
            exit
        ;;
        --hostname)
            value="hostname"
            shift;
            continue;
        ;;
        --origin)
            value="origin"
            shift;
            continue;
        ;;
        --protocol)
            value="protocol"
            shift;
            continue;
        ;;
        --username)
            value="username"
            shift;
            continue;
        ;;
        --password)
            value="password"
            shift;
            continue;
        ;;
        --host)
            value="host"
            shift;
            continue;
        ;;
        --port)
            value="port"
            shift;
            continue;
        ;;
        --pathname)
            value="pathname"
            shift;
            continue;
        ;;
        --search)
            value="search"
            shift;
            continue;
        ;;
        --hash)
            value="hash"
            shift;
            continue;
        ;;
        --clean|--clear|-c)
            CLEAN=true
            shift
            continue
        ;;
        *)
        ;;
    esac
    # code="$code; console.log(new URL(\"$url\"))"
    echo "console.log(new URL(\"$url\").$value);" >> "$file";
done
echo "} catch { console.log('Invalid URL') }" >> "$file"

if $CLEAN; then
    node "$file" | sed 's/^www.//' | sed 's/\.[a-zA-Z0-9]*$//' 2>/dev/null
else
    node "$file" 2>/dev/null
fi
rm -f "$file"
# echo "$@" | xargs -d" " -l echo | awk '{print "console.log(new URL(\"" $0 "\"));"}'