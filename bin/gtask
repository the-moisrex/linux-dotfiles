#!/usr/bin/bash

TASKDATA=".task";
TASKRC=".taskrc";

until [ "$(realpath "$TASKRC")" = "/.taskrc" ] || \
      [ "$(realpath "$TASKRC")" = "/" ] || \
      [ -f "$TASKRC" ]; do
  TASKRC="../${TASKRC}";
done;

until [ "$(realpath "$TASKDATA")" = "/.task" ] || \
      [ "$(realpath "$TASKDATA")" = "/" ] || \
      [ -d "$TASKDATA" ]; do
  TASKDATA="../${TASKDATA}";
done;

TASKRCGIT="$(realpath "$(dirname "$TASKRC")")/.git";
TASKDATAGIT="$(realpath "$(dirname "$TASKDATA")")/.git";


if [ -d "$TASKDATA" ] && [ -f "$TASKRC" ] && [ -d "$TASKRCGIT" ] && [ -d "$TASKDATAGIT" ]; then
  echo "TASKDATA=\"${TASKDATA}\" TASKRC=\"${TASKRC}\" task $*";
  TASKDATA="${TASKDATA}" TASKRC="${TASKRC}" task "$@";
elif [ -f "$TASKRC" ] && [ -d "$TASKRCGIT" ]; then
  echo "TASKRC=\"${TASKRC}\" task $*";
  TASKRC="${TASKRC}" task "$@";
elif [ -d "$TASKDATA" ] && [ -d "$TASKDATAGIT" ]; then
  echo "TASKDATA=\"${TASKDATA}\" task $*";
  TASKDATA="${TASKDATA}" task "$@";
else
  task "$@";
fi;
